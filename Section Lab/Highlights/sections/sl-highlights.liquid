{% comment %}
  SL - Highlights (Section)
  Product-info style highlights: accordion with icon + label list; optional popup per item.
  Data: section blocks (Highlight) or product metafield custom.highlights (list of metaobject references).
{% endcomment %}

{% assign source = section.settings.source | default: 'blocks' %}
{% assign prod = product | default: nil %}
{% assign highlights_list = nil %}
{% if source == 'metafield' and prod != blank %}
  {% assign meta_val = prod.metafields.custom.highlights.value %}
  {% if meta_val != blank and meta_val.size > 0 %}
    {% assign highlights_list = meta_val %}
  {% endif %}
{% endif %}

{% assign use_blocks = false %}
{% if source == 'blocks' %}
  {% for block in section.blocks %}
    {% if block.type == 'highlight' and block.settings.label != blank %}
      {% assign use_blocks = true %}
      {% break %}
    {% endif %}
  {% endfor %}
{% endif %}

{% assign has_content = false %}
{% if highlights_list != nil and highlights_list.size > 0 %}
  {% assign has_content = true %}
{% elsif use_blocks %}
  {% assign has_content = true %}
{% endif %}

{% if has_content %}
  <div id="sl-highlights-section-{{ section.id }}" class="sl-highlights-section" style="width:100%; background: {{ section.settings.background_color }}; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
    <div class="sl-highlights-section__inner" style="{% unless section.settings.full_width %}max-width: {{ section.settings.content_width }}px; margin-left: auto; margin-right: auto;{% endunless %} padding-left: {{ section.settings.padding_inline }}px; padding-right: {{ section.settings.padding_inline }}px;">
      {% render 'sl-highlights',
        highlights: highlights_list,
        section: section,
        use_blocks: use_blocks,
        section_id: section.id,
        heading: section.settings.heading
      %}
    </div>
  </div>
{% elsif request.design_mode %}
  <div id="sl-highlights-section-{{ section.id }}" class="sl-highlights-section" style="padding: 24px; background: #f5f5f5; border: 2px dashed #ccc; text-align: center;">
    <p style="margin: 0; color: #666;">Highlights — Add <strong>Highlight</strong> blocks below, or set <strong>Source</strong> to Product metafield and add <code>custom.highlights</code> (list of Highlight metaobjects) to the product.</p>
  </div>
{% endif %}

{% schema %}
{
  "name": "SL - Highlights",
  "tag": "section",
  "class": "sl-highlights-section",
  "settings": [
    {
      "type": "header",
      "content": "Source"
    },
    {
      "type": "select",
      "id": "source",
      "label": "Data source",
      "options": [
        { "value": "blocks", "label": "Section blocks (add Highlight blocks below)" },
        { "value": "metafield", "label": "Product metafield (custom.highlights)" }
      ],
      "default": "blocks"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Accordion heading",
      "default": "Highlights"
    },
    {
      "type": "header",
      "content": "Section layout"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_inline",
      "label": "Padding left & right",
      "min": 8,
      "max": 80,
      "step": 4,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": false
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Content max width",
      "min": 400,
      "max": 1200,
      "step": 20,
      "default": 800,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "highlight",
      "name": "Highlight",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Highlight text"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "sparkle", "label": "Sparkle" },
            { "value": "leaf", "label": "Leaf" },
            { "value": "recyclable", "label": "Recyclable" },
            { "value": "natural_origin", "label": "Natural origin" },
            { "value": "france", "label": "France" }
          ],
          "default": "sparkle"
        },
        {
          "type": "header",
          "content": "Popup (optional)"
        },
        {
          "type": "text",
          "id": "popup_title",
          "label": "Popup title",
          "info": "If set, clicking this highlight opens a popup"
        },
        {
          "type": "text",
          "id": "popup_subtitle",
          "label": "Popup subtitle"
        },
        {
          "type": "textarea",
          "id": "popup_description",
          "label": "Popup description"
        },
        {
          "type": "image_picker",
          "id": "popup_image",
          "label": "Popup image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SL - Highlights",
      "category": "Product",
      "settings": { "heading": "Highlights" },
      "blocks": [
        {
          "type": "highlight",
          "settings": {
            "label": "Lightweight Oil, Melts Effortlessly",
            "icon": "sparkle"
          }
        },
        {
          "type": "highlight",
          "settings": {
            "label": "Subtle Pearly Shimmer for a Sun-Kissed Glow",
            "icon": "sparkle"
          }
        },
        {
          "type": "highlight",
          "settings": {
            "label": "Recyclable Glass",
            "icon": "recyclable"
          }
        }
      ]
    }
  ],
  "templates": ["product"]
}
{% endschema %}
