{% comment %}
  SL - Free Shipping Progress Bar (Section)
  - Renders a free-shipping progress bar based on the current cart total.
  - Uses the `sl-free-shipping-progress-bar` snippet for the UI and logic.
  - Add this section to your cart template or any page where `cart` is available.
{% endcomment %}

{% assign sid = section.id %}

<div id="sl-fspb-section-{{ sid }}" class="sl-fspb-section-root" style="background: {{ section.settings.background_color }}; padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px 0;">
  <div class="sl-fspb-section-inner" style="{% unless section.settings.full_width %}max-width: {{ section.settings.content_width }}px; margin-left: auto; margin-right: auto;{% endunless %} padding: 0 16px;">
    {% if section.settings.heading != blank %}
      <h2 class="sl-fspb-heading" style="margin: 0 0 8px; font-size: 20px; font-weight: 500; color: {{ section.settings.heading_color }};">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    {% render 'sl-free-shipping-progress-bar',
      threshold_amount: section.settings.threshold_amount,
      success_message: section.settings.success_message,
      progress_message_template: section.settings.progress_message_template,
      tier_message_almost: section.settings.tier_message_almost,
      tier_message_close: section.settings.tier_message_close,
      tier_message_mid: section.settings.tier_message_mid,
      tier_message_far: section.settings.tier_message_far,
      hide_when_cart_empty: section.settings.hide_when_cart_empty,
      fill_color_start: section.settings.fill_color_start,
      fill_color_end: section.settings.fill_color_end,
      show_stripes: section.settings.show_stripes
    %}
  </div>
</div>

<style>
  #sl-fspb-section-{{ sid }}.sl-fspb-section-root {
    width: 100%;
    border: none;
  }

  #sl-fspb-section-{{ sid }} .sl-fspb-section-inner {
    box-sizing: border-box;
  }

  #sl-fspb-section-{{ sid }} .sl-fspb-heading {
    text-align: left;
  }
</style>

{% schema %}
{
  "name": "SL - Free Shipping Progress Bar",
  "tag": "section",
  "class": "sl-free-shipping-progress-bar-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Free shipping progress",
      "info": "Optional heading shown above the bar."
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1c1c1c"
    },
    {
      "type": "range",
      "id": "threshold_amount",
      "label": "Free shipping threshold",
      "min": 0,
      "max": 500,
      "step": 5,
      "default": 50,
      "unit": "$"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "You've unlocked free shipping!"
    },
    {
      "type": "text",
      "id": "progress_message_template",
      "label": "Progress message (fallback)",
      "default": "Add %amount% more for free shipping",
      "info": "Use %amount% as placeholder. Overridden by tier messages below when set."
    },
    {
      "type": "header",
      "content": "Tiered messages (spend to get free shipping)"
    },
    {
      "type": "text",
      "id": "tier_message_almost",
      "label": "Almost there (< $10 away)",
      "default": "Almost there! Just %amount% away from free shipping!",
      "info": "Shown when remaining is under $10. Use %amount%."
    },
    {
      "type": "text",
      "id": "tier_message_close",
      "label": "Getting close (< $30 away)",
      "default": "You're getting close! Add %amount% more for free shipping"
    },
    {
      "type": "text",
      "id": "tier_message_mid",
      "label": "Mid range (< $50 away)",
      "default": "Add %amount% more to get free shipping on your order"
    },
    {
      "type": "text",
      "id": "tier_message_far",
      "label": "Far from threshold",
      "default": "Free shipping when you spend %amount% more"
    },
    {
      "type": "checkbox",
      "id": "hide_when_cart_empty",
      "label": "Hide when cart is empty",
      "default": true
    },
    {
      "type": "header",
      "content": "Progress bar colors"
    },
    {
      "type": "color",
      "id": "fill_color_start",
      "label": "Progress bar gradient start",
      "default": "#4ade80",
      "info": "Lighter end of the bar. Gradient runs to the end color (or theme primary green)."
    },
    {
      "type": "color",
      "id": "fill_color_end",
      "label": "Progress bar gradient end",
      "default": "#16a34a",
      "info": "Darker / primary end. Defaults to green if not set; can match theme primary."
    },
    {
      "type": "checkbox",
      "id": "show_stripes",
      "label": "Show diagonal stripes on bar",
      "default": true
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": false
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Content width (when not full width)",
      "min": 400,
      "max": 1400,
      "step": 20,
      "default": 1000,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 12,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 12,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "SL - Free Shipping Progress Bar",
      "category": "Cart"
    }
  ],
  "templates": ["cart", "page", "product"]
}
{% endschema %}

