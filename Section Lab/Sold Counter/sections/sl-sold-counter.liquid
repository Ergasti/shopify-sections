{% comment %}
  SL - Sold Counter (24h)
  Shows units sold in the last 24 hours with an animated progress bar.

  Data sources, in priority order:
    1. product.metafields.custom.sales_24h        (number — preferred / real data)
    2. product.metafields.custom.sales_goal       (number — bar max; fallback to section setting)
    3. Deterministic fallback estimate, only if "Show fallback" is enabled in settings

  Recommended setup:
    Settings → Custom data → Products → add definitions:
      - Namespace: custom, Key: sales_24h, Type: Number (integer)
      - Namespace: custom, Key: sales_goal, Type: Number (integer)
    Update via Shopify Flow on Order Create / Order Cancel, or via a scheduled job.
{% endcomment %}

{%- liquid
  assign mf_sales = product.metafields.custom.sales_24h.value | default: product.metafields.custom.sales_24h
  assign mf_goal = product.metafields.custom.sales_goal.value | default: product.metafields.custom.sales_goal

  assign sales_count = mf_sales | plus: 0
  assign sales_goal = mf_goal | plus: 0

  if sales_goal == 0
    assign sales_goal = section.settings.default_goal | plus: 0
  endif

  assign has_real_data = false
  if mf_sales != blank and sales_count > 0
    assign has_real_data = true
  endif

  if has_real_data == false and section.settings.use_fallback
    assign seed_a = product.id | modulo: 41
    assign seed_b = product.id | modulo: 7
    assign sales_count = section.settings.fallback_min | plus: seed_a | plus: seed_b
  endif

  assign percent = 0
  if sales_count > 0 and sales_goal > 0
    assign percent = sales_count | times: 100 | divided_by: sales_goal
  endif
  if percent > 100
    assign percent = 100
  endif

  assign should_render = false
  if sales_count > 0
    if has_real_data
      assign should_render = true
    elsif section.settings.use_fallback
      assign should_render = true
    endif
  endif
-%}

{% if should_render %}
  <style>
    #sl-sc-{{ section.id }} {
      --sl-sc-bg: {{ section.settings.background }};
      --sl-sc-text: {{ section.settings.text_color }};
      --sl-sc-accent: {{ section.settings.bar_color }};
      --sl-sc-track: {{ section.settings.bar_track_color }};
      --sl-sc-radius: {{ section.settings.border_radius }}px;
      background: var(--sl-sc-bg);
      color: var(--sl-sc-text);
      border-radius: var(--sl-sc-radius);
      padding: 12px 14px;
      margin: {{ section.settings.margin_top }}px 0 {{ section.settings.margin_bottom }}px;
      border: 1px solid color-mix(in srgb, var(--sl-sc-text) 10%, transparent);
      font-family: var(--font-body-family, inherit);
    }
    #sl-sc-{{ section.id }} .sl-sc__head {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 8px;
      flex-wrap: wrap;
    }
    #sl-sc-{{ section.id }} .sl-sc__icon {
      width: 18px;
      height: 18px;
      flex-shrink: 0;
      color: var(--sl-sc-accent);
      animation: sl-sc-pulse 1.6s ease-in-out infinite;
    }
    #sl-sc-{{ section.id }} .sl-sc__count {
      font-weight: 700;
      font-size: 15px;
      color: var(--sl-sc-accent);
    }
    #sl-sc-{{ section.id }} .sl-sc__label {
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 0.01em;
    }
    #sl-sc-{{ section.id }} .sl-sc__bar {
      position: relative;
      width: 100%;
      height: 8px;
      background: var(--sl-sc-track);
      border-radius: 999px;
      overflow: hidden;
    }
    #sl-sc-{{ section.id }} .sl-sc__fill {
      position: absolute;
      inset: 0;
      width: 0%;
      background: linear-gradient(90deg, var(--sl-sc-accent), color-mix(in srgb, var(--sl-sc-accent) 70%, white));
      border-radius: 999px;
      transition: width 1.4s cubic-bezier(.16,1,.3,1);
      animation: sl-sc-fill-{{ section.id }} 1.4s cubic-bezier(.16,1,.3,1) forwards;
    }
    #sl-sc-{{ section.id }} .sl-sc__sub {
      margin: 8px 0 0;
      font-size: 11px;
      opacity: 0.65;
      letter-spacing: 0.02em;
    }
    @keyframes sl-sc-fill-{{ section.id }} {
      from { width: 0%; }
      to { width: {{ percent }}%; }
    }
    @keyframes sl-sc-pulse {
      0%, 100% { transform: scale(1); opacity: 1; }
      50% { transform: scale(1.15); opacity: 0.7; }
    }
    @media (prefers-reduced-motion: reduce) {
      #sl-sc-{{ section.id }} .sl-sc__fill { animation: none; width: {{ percent }}%; }
      #sl-sc-{{ section.id }} .sl-sc__icon { animation: none; }
    }
  </style>

  <div id="sl-sc-{{ section.id }}" class="sl-sold-counter" role="status" aria-live="polite">
    <div class="sl-sc__head">
      {%- if section.settings.show_icon -%}
        <svg class="sl-sc__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M13.5 0.7c0 1.6 -0.5 2.6 -1.7 3.5 -1.5 1.1 -3.4 3.6 -4 5.1 -0.3 0.8 -0.4 0.6 -0.4 -0.7 0 -1 -0.3 -2 -0.6 -2.3 -0.4 -0.4 -1.1 0.4 -1.9 2.1 -1.7 3.5 -1.6 6.5 0.1 9.6 1.3 2.5 4.5 5 6.4 5 0.6 0 0.4 -0.6 -0.5 -1.6 -1.7 -1.9 -1.9 -3.7 -0.5 -5.2 0.7 -0.7 1.6 -1.1 2.6 -1 1.7 0.2 1.7 0.2 2.7 -1.7 0.6 -1 1.6 -2.4 2.4 -3 1.6 -1.3 2 -1.4 2 0.1 0 0.7 -0.4 1.7 -1 2.3 -1.4 1.4 -1.4 6 0.1 7.4 0.6 0.6 1.1 1.6 1.1 2.2 0 1.7 -2.3 4.5 -3.7 4.5 -0.7 0 -1.3 0.5 -1.3 1 0 0.7 0.7 0.9 2.4 0.4 4.7 -1.5 7.6 -5 7.6 -9.4 0 -3.4 -1.5 -7.5 -3.5 -9.7 -1.6 -1.7 -1.5 -3.4 0.1 -4.4 1 -0.6 1.1 -1 0.4 -1.5 -1.5 -0.9 -7.3 -0.4 -8.4 0.7 -0.6 0.6 -0.4 0.7 0.7 0.6 1.7 -0.2 2 0.7 0.4 1.4 -0.7 0.4 -1.4 -0.5 -1.4 -1.9 0 -3.5 -1.5 -3.5 -3.3z"/>
        </svg>
      {%- endif -%}
      <span class="sl-sc__count">{{ sales_count }}</span>
      <span class="sl-sc__label">
        {%- assign tmpl = section.settings.label_template -%}
        {%- if tmpl contains '[count]' -%}
          {{- tmpl | replace: '[count]', sales_count -}}
        {%- else -%}
          {{ tmpl }}
        {%- endif -%}
      </span>
    </div>
    <div class="sl-sc__bar" aria-label="Sold progress: {{ percent }}%">
      <div class="sl-sc__fill"></div>
    </div>
    {% if section.settings.subtext != blank %}
      <p class="sl-sc__sub">{{ section.settings.subtext | escape }}</p>
    {% endif %}
  </div>
{% endif %}

{% schema %}
{
  "name": "SL - Sold Counter (24h)",
  "tag": "section",
  "class": "sl-sold-counter-section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Copy"
    },
    {
      "type": "text",
      "id": "label_template",
      "label": "Label",
      "info": "Use [count] as placeholder for the number sold.",
      "default": "people bought this in the last 24 hours"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext (optional)",
      "default": "Selling fast — order soon to secure yours."
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Show flame icon",
      "default": true
    },
    {
      "type": "header",
      "content": "Data"
    },
    {
      "type": "paragraph",
      "content": "Reads product.metafields.custom.sales_24h (preferred). Set up via Shopify Flow or a scheduled job."
    },
    {
      "type": "range",
      "id": "default_goal",
      "label": "Progress bar max (default goal)",
      "min": 10,
      "max": 500,
      "step": 5,
      "default": 50,
      "info": "Used when product.metafields.custom.sales_goal is empty."
    },
    {
      "type": "checkbox",
      "id": "use_fallback",
      "label": "Show estimated count when no real data is available",
      "default": false,
      "info": "When enabled, generates a stable per-product estimate. Disable for accurate-only display."
    },
    {
      "type": "range",
      "id": "fallback_min",
      "label": "Fallback minimum",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 8
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background",
      "default": "#FFFAF5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "bar_color",
      "label": "Bar / accent color",
      "default": "#D2691E"
    },
    {
      "type": "color",
      "id": "bar_track_color",
      "label": "Bar track color",
      "default": "#F0E5D8"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 24,
      "step": 1,
      "default": 8,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": 0,
      "max": 60,
      "step": 2,
      "default": 12,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": 0,
      "max": 60,
      "step": 2,
      "default": 12,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "SL - Sold Counter (24h)"
    }
  ]
}
{% endschema %}
