{% comment %}
  SL - Buy 3 Offer (Snippet)
  Mirrors the Free Shipping Progress Bar card/track styling.

  Render anywhere (recommended: product page near ATC):

  {% render 'sl-buy-3-offer',
    product: product,
    offer_qty: 3,
    offer_price: 299,
    regular_total: 750,
    fill_color_start: '#4ade80',
    fill_color_end: '#16a34a',
    show_stripes: true,
    section_id: section.id
  %}

  Notes:
  - Tracks cart quantity for product.id via /cart.js.
  - Amounts are currency units; internally converted to cents.
{% endcomment %}

{% assign sid = section_id | default: id | default: block_id | default: 'sl-buy3-offer' %}

{% assign qualifying_collection_handle = collection_handle | default: '' %}
{% if qualifying_collection_handle == blank and collection != blank %}
  {% assign qualifying_collection_handle = collection.handle | default: '' %}
{% endif %}
{% assign qualifying_collection_title = collection_title | default: '' %}
{% if qualifying_collection_title == blank and collection != blank %}
  {% assign qualifying_collection_title = collection.title | default: '' %}
{% endif %}
{% if qualifying_collection_title == blank %}
  {% assign qualifying_collection_title = qualifying_collection_handle %}
{% endif %}

{% assign offer_qty = offer_qty | default: 3 | plus: 0 %}
{% if offer_qty <= 0 %}{% assign offer_qty = 3 %}{% endif %}

{% assign offer_price_cents = offer_price | default: 299 | plus: 0 | times: 100 %}
{% assign regular_total_cents = regular_total | default: 750 | plus: 0 | times: 100 %}
{% assign savings_cents = regular_total_cents | minus: offer_price_cents %}
{% if savings_cents < 0 %}{% assign savings_cents = 0 %}{% endif %}

{% assign fill_color_start = fill_color_start | default: '#4ade80' | strip %}
{% assign fill_color_end = fill_color_end | default: '#16a34a' | strip %}
{% if show_stripes == false or show_stripes == 'false' %}
  {% assign show_stripes = false %}
{% else %}
  {% assign show_stripes = true %}
{% endif %}

{% assign locale_iso = request.locale.iso_code | default: 'en' %}
{% assign is_rtl = false %}
{% if locale_iso == 'ar' or locale_iso == 'he' or locale_iso == 'fa' or locale_iso == 'ur' or locale_iso == 'yi' %}{% assign is_rtl = true %}{% endif %}

{% if qualifying_collection_handle == blank %}
  {% if request.design_mode %}
    <div style="padding: 16px; border: 1px dashed #ccc; border-radius: 8px; background: #fafafa;">
      <strong>SL - Buy 3 Offer (Snippet)</strong><br>
      {{ 'sections.sl_buy3_offer.missing_collection' | t | default: 'Pass a collection_handle when rendering this snippet.' }}
    </div>
  {% endif %}
{% else %}
  <div
    id="sl-buy3-offer-{{ sid }}"
    class="sl-buy3-offer{% if is_rtl %} sl-buy3-offer--rtl{% endif %}{% unless show_stripes %} sl-buy3-offer--no-stripes{% endunless %}"
    style="--sl-buy3-fill-start: {{ fill_color_start }}; --sl-buy3-fill-end: {{ fill_color_end }};"
    data-sl-buy3-offer
    data-sl-buy3-collection-handle="{{ qualifying_collection_handle }}"
    data-sl-buy3-offer-qty="{{ offer_qty }}"
    data-sl-buy3-offer-price="{{ offer_price_cents }}"
    data-sl-buy3-regular-total="{{ regular_total_cents }}"
    data-sl-buy3-savings="{{ savings_cents }}"
    data-sl-buy3-currency="{{ cart.currency | default: shop.currency | default: 'EGP' }}"
    data-sl-buy3-msg-unlocked="{{ 'sections.sl_buy3_offer.unlocked' | t | default: 'Offer unlocked! You got the deal.' | escape }}"
    data-sl-buy3-msg-remaining="{{ 'sections.sl_buy3_offer.add_more' | t | default: 'Add %count% more to unlock the offer and save %save%.' | escape }}"
    {% if is_rtl %}dir="rtl"{% endif %}
  >
    <div class="sl-buy3-offer__inner">
      <p class="sl-buy3-offer__kicker">
        <span class="sl-buy3-offer__badge">
          <span class="sl-buy3-offer__badge-dot" aria-hidden="true"></span>
          {{ 'sections.sl_buy3_offer.urgency' | t | default: 'Limited-time deal' }}
        </span>
        <span class="sl-buy3-offer__product">{{ qualifying_collection_title }}</span>
      </p>

      <div class="sl-buy3-offer__deal-row">
        <h3 class="sl-buy3-offer__title">
          {{ 'sections.sl_buy3_offer.title' | t | default: 'Buy 3 for' }}
          <span class="sl-buy3-offer__price" data-sl-buy3-offer-price-text>{{ offer_price_cents | money_without_trailing_zeros }}</span>
        </h3>

        <div class="sl-buy3-offer__deal-meta">
          <span class="sl-buy3-offer__save">
            {{ 'sections.sl_buy3_offer.save' | t | default: 'Save' }}
            <span data-sl-buy3-save-value>{{ savings_cents | money_without_trailing_zeros }}</span>
          </span>
          <span class="sl-buy3-offer__instead">
            {{ 'sections.sl_buy3_offer.instead_of' | t | default: 'Instead of' }}
            <span class="sl-buy3-offer__was" data-sl-buy3-regular-total-text>{{ regular_total_cents | money_without_trailing_zeros }}</span>
          </span>
        </div>
      </div>

      <div class="sl-buy3-offer__message" aria-live="polite">
        <span class="sl-buy3-offer__icon" aria-hidden="true">🛍️</span>
        <span class="sl-buy3-offer__message-text" data-sl-buy3-message>
          {{ 'sections.sl_buy3_offer.loading' | t | default: 'Checking your cart…' }}
        </span>
      </div>

      <div class="sl-buy3-offer__track-wrap" style="--progress: 0%">
        <div class="sl-buy3-offer__track">
          <div class="sl-buy3-offer__fill" style="--progress: 0%" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">
            <div class="sl-buy3-offer__stripes"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <style>
    #sl-buy3-offer-{{ sid }}.sl-buy3-offer {
      width: 100%;
      max-width: 520px;
      margin: 16px auto;
      padding: 16px 20px;
      background: #ffffff;
      border-radius: 12px;
      border: 1px solid rgba(15, 23, 42, 0.1);
      box-shadow: 0 14px 34px rgba(15, 23, 42, 0.16);
      overflow: hidden;
      position: relative;
    }
    #sl-buy3-offer-{{ sid }}.sl-buy3-offer::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background: radial-gradient(800px 220px at 20% -20%, rgba(34, 197, 94, 0.18), transparent 60%),
                  radial-gradient(700px 240px at 120% 0%, rgba(59, 130, 246, 0.14), transparent 55%);
    }
    #sl-buy3-offer-{{ sid }} .sl-buy3-offer__inner { display: grid; gap: 10px; }
    #sl-buy3-offer-{{ sid }} .sl-buy3-offer__kicker {
      margin: 0;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
      color: #374151;
      font-size: 0.92rem;
      letter-spacing: 0.01em;
      font-weight: 500;
      position: relative;
    }
    #sl-buy3-offer-{{ sid }} .sl-buy3-offer__badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 4px 10px;
      border-radius: 999px;
      background: rgba(15, 23, 42, 0.06);
      color: #0f172a;
      font-weight: 800;
      font-size: 0.78rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      border: 1px solid rgba(15, 23, 42, 0.12);
      box-shadow: 0 10px 22px rgba(15, 23, 42, 0.12);
      position: relative;
      isolation: isolate;
      animation: sl-buy3-pulse 1.4s ease-in-out infinite;
    }
    #sl-buy3-offer-{{ sid }} .sl-buy3-offer__badge::after {
      content: "";
      position: absolute;
      inset: -6px;
      border-radius: 999px;
      border: 2px solid rgba(34, 197, 94, 0.35);
      opacity: 0;
      transform: scale(0.92);
      animation: sl-buy3-ring 1.4s ease-out infinite;
      z-index: -1;
    }
    #sl-buy3-offer-{{ sid }} .sl-buy3-offer__badge-dot {
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: #22c55e;
      box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.18);
    }
    #sl-buy3-offer-{{ sid }} .sl-buy3-offer__product { font-weight: 600; color: #111827; }
    #sl-buy3-offer-{{ sid }} .sl-buy3-offer__title {
      margin: 0;
      font-size: 1.12rem;
      line-height: 1.25;
      color: #111827;
      letter-spacing: 0.01em;
      font-weight: 900;
      display: inline-flex;
      align-items: baseline;
      gap: 8px;
      text-align: start;
      flex: 1 1 auto;
    }
    #sl-buy3-offer-{{ sid }} .sl-buy3-offer__price { color: #15803d; font-weight: 800; white-space: nowrap; }
    #sl-buy3-offer-{{ sid }} .sl-buy3-offer__deal-row {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
      text-align: start;
    }
    #sl-buy3-offer-{{ sid }} .sl-buy3-offer__deal-meta {
      display: inline-flex;
      align-items: baseline;
      gap: 10px;
      flex-wrap: wrap;
      justify-content: flex-end;
      color: #374151;
      font-size: 0.92rem;
      flex: 0 0 auto;
    }
    #sl-buy3-offer-{{ sid }} .sl-buy3-offer__was { text-decoration: line-through; opacity: 0.85; white-space: nowrap; }
    #sl-buy3-offer-{{ sid }} .sl-buy3-offer__save {
      color: #0f172a;
      font-weight: 850;
      background: rgba(34, 197, 94, 0.14);
      border: 1px solid rgba(34, 197, 94, 0.22);
      padding: 3px 10px;
      border-radius: 999px;
      white-space: nowrap;
      box-shadow: 0 10px 22px rgba(34, 197, 94, 0.18);
    }
    #sl-buy3-offer-{{ sid }} .sl-buy3-offer__instead { white-space: nowrap; opacity: 0.9; }
    #sl-buy3-offer-{{ sid }} .sl-buy3-offer__message {
      margin: 6px 0 0;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      text-align: center;
      color: #374151;
      font-size: 0.95rem;
      letter-spacing: 0.01em;
      font-weight: 520;
    }
    #sl-buy3-offer-{{ sid }} .sl-buy3-offer__icon { font-size: 1.1rem; line-height: 1; }
    #sl-buy3-offer-{{ sid }} .sl-buy3-offer__track-wrap { position: relative; width: 100%; margin-top: 6px; }
    #sl-buy3-offer-{{ sid }} .sl-buy3-offer__track {
      position: relative;
      width: 100%;
      height: 10px;
      background: #eeeeee;
      border-radius: 10px;
      overflow: hidden;
    }
    #sl-buy3-offer-{{ sid }} .sl-buy3-offer__fill {
      position: absolute;
      inset: 0;
      width: var(--progress, 0%);
      height: 100%;
      background: linear-gradient(90deg, var(--sl-buy3-fill-start, #4ade80), var(--sl-buy3-fill-end, #16a34a));
      border-radius: 10px;
      transition: width 0.45s cubic-bezier(0.2, 0.8, 0.2, 1);
      transform-origin: left center;
      overflow: hidden;
    }
    #sl-buy3-offer-{{ sid }} .sl-buy3-offer__stripes {
      position: absolute;
      inset: 0;
      background-image: linear-gradient(
        45deg,
        rgba(255, 255, 255, 0.25) 25%,
        transparent 25%,
        transparent 50%,
        rgba(255, 255, 255, 0.25) 50%,
        rgba(255, 255, 255, 0.25) 75%,
        transparent 75%,
        transparent
      );
      background-size: 14px 14px;
      animation: sl-buy3-stripes 1s linear infinite;
      pointer-events: none;
    }
    #sl-buy3-offer-{{ sid }}.sl-buy3-offer--no-stripes .sl-buy3-offer__stripes { display: none; }
    @keyframes sl-buy3-stripes { from { background-position: 0 0; } to { background-position: 14px 0; } }
    @keyframes sl-buy3-pulse {
      0%, 100% { transform: translateZ(0) scale(1); }
      50% { transform: translateZ(0) scale(1.03); }
    }
    @keyframes sl-buy3-ring {
      0% { opacity: 0.0; transform: scale(0.92); }
      30% { opacity: 0.55; }
      100% { opacity: 0; transform: scale(1.12); }
    }
    #sl-buy3-offer-{{ sid }}.sl-buy3-offer--rtl .sl-buy3-offer__deal-row { flex-direction: row-reverse; }
    #sl-buy3-offer-{{ sid }}.sl-buy3-offer--rtl .sl-buy3-offer__deal-meta { justify-content: flex-start; }
    @media screen and (max-width: 749px) {
      #sl-buy3-offer-{{ sid }} .sl-buy3-offer__deal-row { justify-content: flex-start; }
      #sl-buy3-offer-{{ sid }} .sl-buy3-offer__deal-meta { width: 100%; justify-content: flex-start; }
    }
    @media (prefers-reduced-motion: reduce) {
      #sl-buy3-offer-{{ sid }} .sl-buy3-offer__fill,
      #sl-buy3-offer-{{ sid }} .sl-buy3-offer__stripes,
      #sl-buy3-offer-{{ sid }} .sl-buy3-offer__badge,
      #sl-buy3-offer-{{ sid }} .sl-buy3-offer__badge::after {
        animation: none !important;
        transition: none !important;
      }
    }
  </style>

  <script>
  (function() {
    var root = document.getElementById('sl-buy3-offer-{{ sid }}');
    if (!root) return;

    function formatMoney(cents, currency) {
      cents = Math.max(0, cents || 0);
      currency = (currency || '').toUpperCase() || 'EGP';
      try {
        if (window.Shopify && typeof window.Shopify.formatMoney === 'function') {
          var fmt = window.money_format || window.Shopify.money_format || '${{amount}}';
          var fmtNoDecimals = fmt
            .replace('amount_with_comma_separator', 'amount_no_decimals_with_comma_separator')
            .replace('amount_with_period_and_space_separator', 'amount_no_decimals_with_period_and_space_separator')
            .replace('amount_with_space_separator', 'amount_no_decimals_with_space_separator')
            .replace('amount_with_apostrophe_separator', 'amount_no_decimals_with_apostrophe_separator')
            .replace('amount', 'amount_no_decimals');
          return window.Shopify.formatMoney(cents, fmtNoDecimals);
        }
      } catch (e) {}
      try {
        return new Intl.NumberFormat(undefined, { style: 'currency', currency: currency, minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(cents / 100);
      } catch (e2) {}
      return String(Math.round(cents / 100));
    }

    var collectionCache = window.__slBuy3CollectionCache = window.__slBuy3CollectionCache || {};

    function fetchCollectionProductIds(handle) {
      if (!handle) return Promise.resolve({});
      if (collectionCache[handle] && collectionCache[handle].promise) return collectionCache[handle].promise;

      var ids = {};
      var page = 1;
      var maxPages = 10;

      function loadNext() {
        var url = '/collections/' + encodeURIComponent(handle) + '/products.json?limit=250&page=' + page;
        return fetch(url, { credentials: 'same-origin' })
          .then(function(r) { return r.json(); })
          .then(function(data) {
            var products = data && data.products ? data.products : [];
            for (var i = 0; i < products.length; i++) {
              if (products[i] && products[i].id) ids[String(products[i].id)] = true;
            }
            if (!products.length || page >= maxPages) return ids;
            page += 1;
            return loadNext();
          });
      }

      collectionCache[handle] = collectionCache[handle] || {};
      collectionCache[handle].promise = loadNext().catch(function() { return ids; });
      return collectionCache[handle].promise;
    }

    function getQtyForCollection(cart, productIdsMap) {
      if (!cart || !cart.items || !cart.items.length) return 0;
      var sum = 0;
      for (var i = 0; i < cart.items.length; i++) {
        var it = cart.items[i];
        if (productIdsMap && productIdsMap[String(it.product_id)] === true) sum += (it.quantity || 0);
      }
      return sum;
    }

    function updateUI(cart, productIdsMap) {
      var offerQty = parseInt(root.getAttribute('data-sl-buy3-offer-qty') || '3', 10) || 3;
      var offerPrice = parseInt(root.getAttribute('data-sl-buy3-offer-price') || '0', 10) || 0;
      var regularTotal = parseInt(root.getAttribute('data-sl-buy3-regular-total') || '0', 10) || 0;
      var savings = parseInt(root.getAttribute('data-sl-buy3-savings') || '0', 10) || 0;
      var currency = root.getAttribute('data-sl-buy3-currency') || (cart && cart.currency) || 'EGP';

      var qty = getQtyForCollection(cart, productIdsMap);
      var remaining = Math.max(0, offerQty - qty);
      var progress = Math.min(100, (qty / offerQty) * 100);

      var fillEl = root.querySelector('.sl-buy3-offer__fill');
      var trackWrap = root.querySelector('.sl-buy3-offer__track-wrap');
      var msgEl = root.querySelector('[data-sl-buy3-message]');
      var offerPriceText = root.querySelector('[data-sl-buy3-offer-price-text]');
      var regularTotalText = root.querySelector('[data-sl-buy3-regular-total-text]');
      var saveValue = root.querySelector('[data-sl-buy3-save-value]');

      if (offerPriceText) offerPriceText.textContent = formatMoney(offerPrice, currency);
      if (regularTotalText) regularTotalText.textContent = formatMoney(regularTotal, currency);
      if (saveValue) saveValue.textContent = formatMoney(savings, currency);

      if (fillEl) {
        fillEl.style.setProperty('--progress', progress + '%');
        fillEl.setAttribute('aria-valuenow', String(Math.round(progress)));
      }
      if (trackWrap) trackWrap.style.setProperty('--progress', progress + '%');

      if (!msgEl) return;
      if (remaining <= 0) {
        msgEl.textContent = root.getAttribute('data-sl-buy3-msg-unlocked') || 'Offer unlocked!';
      } else {
        var tpl = root.getAttribute('data-sl-buy3-msg-remaining') || 'Add %count% more to unlock.';
        msgEl.textContent = tpl
          .replace(/%count%/g, String(remaining))
          .replace(/%save%/g, formatMoney(savings, currency));
      }
    }

    function refresh() {
      var handle = root.getAttribute('data-sl-buy3-collection-handle');
      fetchCollectionProductIds(handle)
        .then(function(idsMap) {
          return fetch('/cart.js', { credentials: 'same-origin' })
            .then(function(r) { return r.json(); })
            .then(function(cart) { updateUI(cart, idsMap); });
        })
        .catch(function() {});
    }

    refresh();

    ['cart:refresh', 'cart:change', 'cart:updated', 'product:added'].forEach(function(eventName) {
      document.addEventListener(eventName, function(e) {
        var detail = e && e.detail ? e.detail : null;
        var cart = detail && (detail.cart || detail);
        if (!cart) { setTimeout(refresh, 120); return; }
        var handle = root.getAttribute('data-sl-buy3-collection-handle');
        fetchCollectionProductIds(handle).then(function(idsMap) { updateUI(cart, idsMap); }).catch(function() { updateUI(cart, {}); });
      });
    });

    var _fetch = window.fetch;
    if (typeof _fetch === 'function') {
      window.fetch = function() {
        var url = (arguments[0] && arguments[0].url) ? arguments[0].url : arguments[0];
        var watches = typeof url === 'string' && (
          url.indexOf('/cart/add') !== -1 ||
          url.indexOf('/cart/change') !== -1 ||
          url.indexOf('/cart/update') !== -1 ||
          url.indexOf('/cart/clear') !== -1
        );
        return _fetch.apply(this, arguments).then(function(res) {
          if (watches) setTimeout(refresh, 150);
          return res;
        });
      };
    }
  })();
  </script>
{% endif %}

