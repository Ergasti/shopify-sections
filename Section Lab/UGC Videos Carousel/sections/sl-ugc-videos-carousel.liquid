{% comment %}
  SL - UGC Videos Carousel (standalone)
  Swiper of UGC-style video cards (video only, no products). Click opens overlay with full video.
  Data: section blocks (one video per block).
  See README.md.
{% endcomment %}

{% assign has_videos = false %}
{% for block in section.blocks %}
  {% assign vf = block.settings.video_file %}
  {% assign mp4 = vf.sources | where: 'format', 'mp4' | first %}
  {% if mp4 and mp4.url != blank %}
    {% assign has_videos = true %}
    {% break %}
  {% endif %}
{% endfor %}

{% unless has_videos %}
  {% if request.design_mode %}
    <div id="sl-ugc-vc-{{ section.id }}" class="sl-ugc-vc-root" style="padding: 24px; background: #f5f5f5; font-family: monospace; font-size: 12px;">
      <p style="margin: 0; color: #666;">UGC Videos Carousel — Add “Video” blocks and pick a video file for each.</p>
    </div>
  {% endif %}
{% else %}
{% assign locale_iso = request.locale.iso_code | default: 'en' %}
{% assign is_rtl = false %}
{% if locale_iso == 'ar' or locale_iso == 'he' or locale_iso == 'fa' %}{% assign is_rtl = true %}{% endif %}

<div id="sl-ugc-vc-{{ section.id }}" class="sl-ugc-vc-root{% if is_rtl %} sl-ugc-vc-rtl{% endif %}"{% if is_rtl %} dir="rtl"{% endif %} style="background: {{ section.settings.background_color }}; padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px 0; --sl-ugc-vc-slide-gap: {{ section.settings.slide_gap | default: 16 }}px; --sl-ugc-vc-slides-per-view: {{ section.settings.slides_desktop | default: 5 }};">
  <div class="sl-ugc-vc-inner" style="{% unless section.settings.full_width %}max-width: {{ section.settings.content_width }}px; margin-left: auto; margin-right: auto;{% endunless %} padding: 0 16px;">
    <div class="sl-ugc-vc-title">
      {% if section.settings.heading != blank %}<h2 class="sl-ugc-vc-heading" style="font-size: {{ section.settings.heading_size }}px; color: {{ section.settings.heading_color }}; margin: 0;">{{ section.settings.heading }}</h2>{% endif %}
      {% if section.settings.subheading != blank %}<p class="sl-ugc-vc-subheading" style="font-size: {{ section.settings.subheading_size }}px; color: {{ section.settings.subheading_color }}; margin: 8px 0 0 0;">{{ section.settings.subheading }}</p>{% endif %}
    </div>

    <div class="sl-ugc-vc-swiper swiper">
      <div class="swiper-wrapper">
        {% assign max_videos = section.settings.max_videos | default: 0 %}
        {% assign videos_out = 0 %}
        {% for block in section.blocks %}
          {% if max_videos > 0 and videos_out >= max_videos %}{% break %}{% endif %}
          {% assign video_file = block.settings.video_file %}
          {% assign mp4 = video_file.sources | where: 'format', 'mp4' | first %}
          {% if mp4 and mp4.url != blank %}
            {% assign full_video_url = mp4.url %}
            {% assign preview_url = full_video_url %}
            <div class="swiper-slide sl-ugc-vc-slide" {{ block.shopify_attributes }}>
              <div class="sl-ugc-vc-card"
                data-full-video="{{ full_video_url | escape }}"
                role="button"
                tabindex="0">
                <div class="sl-ugc-vc-video-wrap">
                  <video
                    data-src="{{ preview_url }}"
                    poster="{% if video_file.preview_image %}{{ video_file.preview_image | image_url: width: 600 }}{% endif %}"
                    muted loop playsinline
                    preload="none"
                    loading="lazy"
                    class="sl-ugc-vc-video"
                  ></video>
                </div>
                {% if block.settings.caption != blank %}
                  <p class="sl-ugc-vc-caption" style="color: {{ section.settings.caption_color }};">{{ block.settings.caption }}</p>
                {% endif %}
              </div>
            </div>
            {% assign videos_out = videos_out | plus: 1 %}
          {% endif %}
        {% endfor %}
      </div>
      <div class="swiper-button-prev"></div>
      <div class="swiper-button-next"></div>
    </div>
  </div>
</div>

<div id="sl-ugc-vc-overlay-{{ section.id }}" class="sl-ugc-vc-overlay{% if is_rtl %} sl-ugc-vc-rtl{% endif %}" role="dialog" aria-modal="true" aria-label="{{ 'sections.sl_ugc_carousel.close_video' | t }}" hidden>
  <span class="sl-ugc-vc-overlay-close" id="sl-ugc-vc-overlay-close-{{ section.id }}" aria-label="{{ 'sections.sl_ugc_carousel.close_video' | t }}"></span>
  <div class="sl-ugc-vc-full-container">
    <div id="sl-ugc-vc-overlay-video-slot-{{ section.id }}" class="sl-ugc-vc-overlay-video-slot">
      <video id="sl-ugc-vc-full-video-{{ section.id }}" class="sl-ugc-vc-full-video" autoplay playsinline loop controls></video>
    </div>
    <div id="sl-ugc-vc-loading-{{ section.id }}" class="sl-ugc-vc-loading" hidden>{{ 'sections.sl_ugc_carousel.loading' | t }}</div>
  </div>
</div>

<style>
  #sl-ugc-vc-{{ section.id }} .sl-ugc-vc-swiper { overflow: hidden; position: relative; padding: 20px 0 48px; min-height: 280px; }
  #sl-ugc-vc-{{ section.id }} .sl-ugc-vc-title { margin-bottom: 16px; text-align: {{ section.settings.heading_alignment }}; }
  #sl-ugc-vc-{{ section.id }} .swiper-wrapper {
    display: flex;
    flex-wrap: nowrap;
  }
  #sl-ugc-vc-{{ section.id }} .swiper-slide {
    height: auto;
    box-sizing: border-box;
    flex: 0 0 auto;
    min-width: 0;
  }

  #sl-ugc-vc-{{ section.id }} .sl-ugc-vc-card {
    position: relative;
    cursor: pointer;
    display: flex;
    flex-direction: column;
  }
  #sl-ugc-vc-{{ section.id }} .sl-ugc-vc-video-wrap {
    aspect-ratio: 9 / 16;
    background: #000;
    position: relative;
    flex-shrink: 0;
    border-radius: {{ section.settings.card_radius }}px;
    overflow: hidden;
    min-height: 180px;
  }
  #sl-ugc-vc-{{ section.id }} .sl-ugc-vc-video {
    width: 100%; height: 100%; object-fit: cover; display: block; pointer-events: none;
    background: #000;
  }
  #sl-ugc-vc-{{ section.id }} .sl-ugc-vc-caption {
    margin: 10px 0 0 0;
    font-size: 12px;
    line-height: 1.3;
    text-align: center;
  }

  #sl-ugc-vc-{{ section.id }} .swiper-button-prev, #sl-ugc-vc-{{ section.id }} .swiper-button-next,
  #sl-ugc-vc-{{ section.id }} .swiper-button-prev::after, #sl-ugc-vc-{{ section.id }} .swiper-button-next::after { color: {{ section.settings.arrow_color }} !important; }

  #sl-ugc-vc-overlay-{{ section.id }}.sl-ugc-vc-overlay {
    position: fixed; inset: 0; z-index: 99999999;
    background: rgba(255, 255, 255, 0.8);
    -webkit-backdrop-filter: blur(10px);
    backdrop-filter: blur(10px);
    display: block;
  }
  #sl-ugc-vc-overlay-{{ section.id }}.sl-ugc-vc-overlay[hidden] { display: none !important; }
  #sl-ugc-vc-overlay-{{ section.id }} .sl-ugc-vc-overlay-close {
    position: absolute; top: 10px; right: 10px; z-index: 10001; width: 32px; height: 32px;
    cursor: pointer; background: rgba(0,0,0,0.08); border-radius: 50%; transition: background 0.2s;
  }
  #sl-ugc-vc-overlay-{{ section.id }} .sl-ugc-vc-overlay-close:hover { background: rgba(0,0,0,0.15); }
  #sl-ugc-vc-overlay-{{ section.id }} .sl-ugc-vc-overlay-close::before,
  #sl-ugc-vc-overlay-{{ section.id }} .sl-ugc-vc-overlay-close::after {
    content: ''; position: absolute; left: 50%; top: 50%; width: 16px; height: 2px; background: #333; transform: translate(-50%,-50%) rotate(45deg);
  }
  #sl-ugc-vc-overlay-{{ section.id }} .sl-ugc-vc-overlay-close::after { transform: translate(-50%,-50%) rotate(-45deg); }
  #sl-ugc-vc-overlay-{{ section.id }}.sl-ugc-vc-rtl .sl-ugc-vc-overlay-close { right: auto; left: 10px; }

  #sl-ugc-vc-overlay-{{ section.id }} .sl-ugc-vc-full-container {
    width: 400px;
    max-width: 95%;
    margin: 48px auto 24px;
    position: relative;
    max-height: calc(100% - 80px);
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }
  #sl-ugc-vc-overlay-{{ section.id }} .sl-ugc-vc-overlay-video-slot { position: relative; width: 100%; }
  #sl-ugc-vc-overlay-{{ section.id }} .sl-ugc-vc-full-video {
    border-radius: 30px;
    width: 100%;
    display: block;
  }
  #sl-ugc-vc-overlay-{{ section.id }} .sl-ugc-vc-loading {
    display: none;
    position: absolute; left: 50%; top: 40%; transform: translate(-50%,-50%);
    color: #999; font-size: 14px;
  }
  #sl-ugc-vc-overlay-{{ section.id }} .sl-ugc-vc-loading:not([hidden]) { display: block; }
</style>

<script>
(function() {
  var sectionId = '{{ section.id }}';
  var root = document.getElementById('sl-ugc-vc-' + sectionId);
  if (!root) return;
  var SWIPER_CSS = 'https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css';
  var SWIPER_JS = 'https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js';

  function loadSwiper(cb) {
    if (typeof Swiper !== 'undefined') { cb(); return; }
    var link = document.createElement('link');
    link.rel = 'stylesheet';
    link.href = SWIPER_CSS;
    document.head.appendChild(link);
    var s = document.createElement('script');
    s.src = SWIPER_JS;
    s.onload = cb;
    s.onerror = function() { cb(); };
    document.head.appendChild(s);
  }

  function ensureVideoSrc(v) {
    if (!v) return;
    var src = v.getAttribute('data-src');
    if (src && !v.src) v.src = src;
  }

  function playVisibleVideos(swiper) {
    if (!swiper || !swiper.slides) return;
    var activeIdx = swiper.activeIndex || 0;
    var perView = swiper.params.slidesPerView || 1;
    swiper.slides.forEach(function(slide, i) {
      var v = slide.querySelector('.sl-ugc-vc-video');
      if (!v) return;
      if (i >= activeIdx && i < activeIdx + Math.ceil(perView)) {
        ensureVideoSrc(v);
        v.muted = true;
        v.loop = true;
        v.play().catch(function(){});
      } else {
        v.pause();
      }
    });
  }

  function run() {
    var r = document.getElementById('sl-ugc-vc-' + sectionId);
    if (!r) return;
    var swiperEl = r.querySelector('.sl-ugc-vc-swiper');
    var cards = r.querySelectorAll('.sl-ugc-vc-card');
    var overlay = document.getElementById('sl-ugc-vc-overlay-' + sectionId);
    var overlayVideo = document.getElementById('sl-ugc-vc-full-video-' + sectionId);
    var overlayClose = document.getElementById('sl-ugc-vc-overlay-close-' + sectionId);
    var overlayLoading = document.getElementById('sl-ugc-vc-loading-' + sectionId);

    function openOverlay(card) {
      var fullVideo = card.getAttribute('data-full-video') || '';
      if (!overlay || !overlayVideo || !fullVideo) return;

      r.querySelectorAll('.sl-ugc-vc-video').forEach(function(v) { v.pause(); });

      overlay.removeAttribute('hidden');
      document.body.style.overflow = 'hidden';

      function hideOverlayLoading() {
        if (overlayLoading) overlayLoading.setAttribute('hidden', '');
      }

      if (overlayLoading) overlayLoading.removeAttribute('hidden');
      overlayVideo.style.display = '';
      overlayVideo.muted = true;
      overlayVideo.volume = 0;
      overlayVideo.loop = true;
      overlayVideo.src = fullVideo;
      overlayVideo.load();
      overlayVideo.play().catch(function() {});
      var loadHide = setTimeout(hideOverlayLoading, 1500);
      function onReady() {
        clearTimeout(loadHide);
        hideOverlayLoading();
        overlayVideo.muted = false;
        overlayVideo.volume = 1;
      }
      overlayVideo.addEventListener('playing', onReady, { once: true });
      overlayVideo.addEventListener('canplay', function() { clearTimeout(loadHide); hideOverlayLoading(); }, { once: true });
    }

    function closeOverlay() {
      if (overlay) {
        overlay.setAttribute('hidden', '');
        document.body.style.overflow = '';
      }
      if (overlayVideo) {
        overlayVideo.pause();
        overlayVideo.removeAttribute('src');
        overlayVideo.style.display = '';
      }
      if (overlayLoading) overlayLoading.setAttribute('hidden', '');
      r.querySelectorAll('.sl-ugc-vc-video').forEach(function(v) {
        v.muted = true;
        v.loop = true;
        v.play().catch(function(){});
      });
    }

    loadSwiper(function() {
      if (swiperEl.swiper) return;
      if (typeof Swiper !== 'undefined') {
        try {
          new Swiper(swiperEl, {
            slidesPerView: window.innerWidth <= 768 ? {{ section.settings.slides_mobile }} : {{ section.settings.slides_desktop }},
            spaceBetween: {{ section.settings.slide_gap }},
            loop: false,
            breakpoints: {
              320: { slidesPerView: {{ section.settings.slides_mobile }} },
              769: { slidesPerView: {{ section.settings.slides_desktop }} }
            },
            navigation: {
              nextEl: r.querySelector('.swiper-button-next'),
              prevEl: r.querySelector('.swiper-button-prev')
            },
            on: {
              init: function(swiper) { playVisibleVideos(swiper); },
              slideChangeTransitionEnd: function(swiper) { playVisibleVideos(swiper); }
            }
          });
        } catch (e) {}
      }
      if (!swiperEl.swiper) {
        var wrapper = swiperEl.querySelector('.swiper-wrapper');
        if (wrapper) {
          swiperEl.style.overflowX = 'auto';
          swiperEl.style.overflowY = 'visible';
          wrapper.style.display = 'flex';
          wrapper.style.gap = '{{ section.settings.slide_gap }}px';
          wrapper.style.flexWrap = 'nowrap';
        }
        var next = r.querySelector('.swiper-button-next');
        var prev = r.querySelector('.swiper-button-prev');
        if (next) next.style.display = 'none';
        if (prev) prev.style.display = 'none';
      }
      r.querySelectorAll('.sl-ugc-vc-card video').forEach(function(v) {
        ensureVideoSrc(v);
        v.muted = true;
        v.loop = true;
        v.play().catch(function(){});
      });

      cards.forEach(function(card) {
        card.addEventListener('click', function(e) {
          e.preventDefault();
          openOverlay(card);
        });
        card.addEventListener('keydown', function(e) {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openOverlay(card); }
        });
      });

      if (overlayClose) overlayClose.addEventListener('click', closeOverlay);
      if (overlay) {
        overlay.addEventListener('click', function(e) {
          if (e.target === overlay) closeOverlay();
        });
      }
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && overlay && !overlay.hasAttribute('hidden')) closeOverlay();
    });
  }

  function startWhenVisible() {
    var r = document.getElementById('sl-ugc-vc-' + sectionId);
    if (!r) return;
    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function(entries) {
        if (!entries[0].isIntersecting) return;
        io.disconnect();
        run();
      }, { rootMargin: '120px', threshold: 0 });
      io.observe(r);
    } else {
      run();
    }
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', startWhenVisible);
  else startWhenVisible();
})();
</script>
{% endunless %}

{% schema %}
{
  "name": "SL - UGC Videos Carousel",
  "tag": "section",
  "class": "sl-ugc-videos-carousel",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Real stories"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 18,
      "max": 42,
      "step": 2,
      "default": 28,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading size",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#171717"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#545454"
    },
    {
      "type": "header",
      "content": "Slider"
    },
    {
      "type": "range",
      "id": "slides_desktop",
      "label": "Slides per view (desktop)",
      "min": 2,
      "max": 7,
      "step": 1,
      "default": 5
    },
    {
      "type": "range",
      "id": "slides_mobile",
      "label": "Slides per view (mobile)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "slide_gap",
      "label": "Gap between slides",
      "min": 8,
      "max": 32,
      "step": 4,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "max_videos",
      "label": "Max videos",
      "info": "Limit slides shown. 0 = no limit.",
      "min": 0,
      "max": 50,
      "step": 1,
      "default": 0
    },
    {
      "type": "header",
      "content": "Cards"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Video corner radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "default": 12,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "caption_color",
      "label": "Caption color",
      "default": "#545454"
    },
    {
      "type": "header",
      "content": "Section"
    },
    {
      "type": "color",
      "id": "arrow_color",
      "label": "Arrow color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": false
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Content max width",
      "min": 800,
      "max": 1600,
      "step": 40,
      "default": 1400,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "settings": [
        {
          "type": "video",
          "id": "video_file",
          "label": "Video"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption",
          "info": "Optional short line under the video."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SL - UGC Videos Carousel",
      "category": "Media",
      "blocks": [
        { "type": "video" },
        { "type": "video" },
        { "type": "video" }
      ]
    }
  ]
}
{% endschema %}
