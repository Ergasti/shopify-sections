  #sl-ugc-hp-{{ section.id }} .sl-ugc-hp-add-btn:hover:not(:disabled),
  #sl-ugc-hp-overlay-{{ section.id }} .sl-ugc-hp-overlay-product .sl-ugc-hp-add-btn:hover:not(:disabled) { opacity: 0.9; }
  #sl-ugc-hp-{{ section.id }} .sl-ugc-hp-add-btn:disabled,
  #sl-ugc-hp-overlay-{{ section.id }} .sl-ugc-hp-overlay-product .sl-ugc-hp-add-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  @keyframes sl-ugc-hp-pulse { 0%, 100% { opacity: 0.8; } 50% { opacity: 0.5; } }
  #sl-ugc-hp-{{ section.id }} .sl-ugc-hp-add-btn.is-loading,
  #sl-ugc-hp-overlay-{{ section.id }} .sl-ugc-hp-overlay-product .sl-ugc-hp-add-btn.is-loading { animation: sl-ugc-hp-pulse 0.8s ease-in-out infinite; pointer-events: none; }

  #sl-ugc-hp-{{ section.id }} .swiper-button-prev, #sl-ugc-hp-{{ section.id }} .swiper-button-next,
  #sl-ugc-hp-{{ section.id }} .swiper-button-prev::after, #sl-ugc-hp-{{ section.id }} .swiper-button-next::after { color: {{ section.settings.arrow_color }} !important; }

  /* ===== OVERLAY (frosted glass) ===== */
  #sl-ugc-hp-overlay-{{ section.id }}.sl-ugc-hp-overlay {
    position: fixed; inset: 0; z-index: 99999999;
    background: rgba(255, 255, 255, 0.8);
    -webkit-backdrop-filter: blur(10px);
    backdrop-filter: blur(10px);
    display: block;
  }
  #sl-ugc-hp-overlay-{{ section.id }}.sl-ugc-hp-overlay[hidden] { display: none !important; }
  #sl-ugc-hp-overlay-{{ section.id }} .sl-ugc-hp-overlay-close {
    position: absolute; top: 10px; right: 10px; z-index: 10001; width: 32px; height: 32px;
    cursor: pointer; background: rgba(0,0,0,0.08); border-radius: 50%; transition: background 0.2s;
  }
  #sl-ugc-hp-overlay-{{ section.id }} .sl-ugc-hp-overlay-close:hover { background: rgba(0,0,0,0.15); }
  #sl-ugc-hp-overlay-{{ section.id }} .sl-ugc-hp-overlay-close::before,
  #sl-ugc-hp-overlay-{{ section.id }} .sl-ugc-hp-overlay-close::after {
    content: ''; position: absolute; left: 50%; top: 50%; width: 16px; height: 2px; background: #333; transform: translate(-50%,-50%) rotate(45deg);
  }
  #sl-ugc-hp-overlay-{{ section.id }} .sl-ugc-hp-overlay-close::after { transform: translate(-50%,-50%) rotate(-45deg); }
  #sl-ugc-hp-overlay-{{ section.id }}.sl-ugc-hp-rtl .sl-ugc-hp-overlay-close { right: auto; left: 10px; }

  #sl-ugc-hp-overlay-{{ section.id }} .sl-ugc-hp-full-container {
    width: 400px;
    max-width: 95%;
    margin: 2px auto;
