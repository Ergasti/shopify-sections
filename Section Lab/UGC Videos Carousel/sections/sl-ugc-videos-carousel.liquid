  #sl-ugc-hp-overlay-{{ section.id }} .sl-ugc-hp-overlay-video-slot {
    position: relative;
    width: 100%;
  }
  #sl-ugc-hp-overlay-{{ section.id }} .sl-ugc-hp-full-video {
