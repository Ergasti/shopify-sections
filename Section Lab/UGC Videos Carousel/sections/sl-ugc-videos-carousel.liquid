  #sl-ugc-hp-overlay-{{ section.id }} .sl-ugc-hp-loading:not([hidden]) { display: block; }
</style>

<script>
(function() {
  var sectionId = '{{ section.id }}';
  var root = document.getElementById('sl-ugc-hp-' + sectionId);
  if (!root) return;
  var SWIPER_CSS = 'https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css';
  var SWIPER_JS = 'https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js';

  function loadSwiper(cb) {
    if (typeof Swiper !== 'undefined') { cb(); return; }
    var link = document.createElement('link');
    link.rel = 'stylesheet';
    link.href = SWIPER_CSS;
    document.head.appendChild(link);
    var s = document.createElement('script');
    s.src = SWIPER_JS;
    s.onload = cb;
    s.onerror = function() { cb(); };
    document.head.appendChild(s);
  }

  function ensureVideoSrc(v) {
    if (!v) return;
    var src = v.getAttribute('data-src');
    if (src && !v.src) v.src = src;
  }

  function playVisibleVideos(swiper) {
    if (!swiper || !swiper.slides) return;
    var activeIdx = swiper.activeIndex || 0;
    var perView = swiper.params.slidesPerView || 1;
    swiper.slides.forEach(function(slide, i) {
      var v = slide.querySelector('.sl-ugc-hp-video');
      if (!v) return;
      if (i >= activeIdx && i < activeIdx + Math.ceil(perView)) {
        ensureVideoSrc(v);
        v.muted = true;
        v.loop = true;
        v.play().catch(function(){});
      } else {
        v.pause();
      }
    });
  }

  function run() {
    var r = document.getElementById('sl-ugc-hp-' + sectionId);
    if (!r) return;
    var swiperEl = r.querySelector('.sl-ugc-hp-swiper');
    var cards = r.querySelectorAll('.sl-ugc-hp-card');
    var overlay = document.getElementById('sl-ugc-hp-overlay-' + sectionId);
    var overlayVideo = document.getElementById('sl-ugc-hp-full-video-' + sectionId);
    var overlayClose = document.getElementById('sl-ugc-hp-overlay-close-' + sectionId);
    var overlayImg = document.getElementById('sl-ugc-hp-overlay-img-' + sectionId);
    var overlayName = document.getElementById('sl-ugc-hp-overlay-name-' + sectionId);
    var overlayPrice = document.getElementById('sl-ugc-hp-overlay-price-' + sectionId);
    var overlayCompare = document.getElementById('sl-ugc-hp-overlay-compare-' + sectionId);
    var overlayLoading = document.getElementById('sl-ugc-hp-loading-' + sectionId);
    var rootPath = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) || '/';
    var i18nAdd = {
      add: {{ 'sections.sl_ugc_hp.add_to_cart' | t | json }},
      adding: {{ 'sections.sl_ugc_hp.adding' | t | json }},
      added: {{ 'sections.sl_ugc_hp.added' | t | json }}
    };

    function openOverlay(card) {
      var fullVideo = card.getAttribute('data-full-video') || '';
      var productUrl = card.getAttribute('data-product-url') || '#';
      var productTitle = card.getAttribute('data-product-title') || '';
      var productImage = card.getAttribute('data-product-image') || '';
      var productPrice = card.getAttribute('data-product-price') || '';
      var productCompare = card.getAttribute('data-product-compare') || '';
      var productRating = card.getAttribute('data-product-rating') || '';
      var productReviews = card.getAttribute('data-product-reviews') || '';
      var ctaText = card.getAttribute('data-cta-text') || 'Add to cart';
      var variantId = card.getAttribute('data-variant-id') || '';

      if (!overlay || !overlayVideo) return;

      r.querySelectorAll('.sl-ugc-hp-video').forEach(function(v) { v.pause(); });

      var overlaySlot = document.getElementById('sl-ugc-hp-overlay-video-slot-' + sectionId);
      if (overlaySlot) {
        var prev = overlaySlot.querySelector('.sl-ugc-hp-overlay-metafield-clone');
        if (prev) prev.remove();
      }

      overlay.removeAttribute('hidden');
      document.body.style.overflow = 'hidden';

      function hideOverlayLoading() {
        if (overlayLoading) overlayLoading.setAttribute('hidden', '');
      }

      if (fullVideo) {
        if (overlayLoading) overlayLoading.removeAttribute('hidden');
        overlayVideo.style.display = '';
        overlayVideo.muted = true;
        overlayVideo.volume = 0;
        overlayVideo.loop = true;
        overlayVideo.src = fullVideo;
        overlayVideo.load();
        overlayVideo.play().catch(function() {});
        var loadHide = setTimeout(hideOverlayLoading, 1500);
        function onReady() {
          clearTimeout(loadHide);
          hideOverlayLoading();
          overlayVideo.muted = false;
          overlayVideo.volume = 1;
        }
        overlayVideo.addEventListener('playing', onReady, { once: true });
        overlayVideo.addEventListener('canplay', function() { clearTimeout(loadHide); hideOverlayLoading(); }, { once: true });
      } else {
        hideOverlayLoading();
        var metafieldWrap = card.querySelector('.sl-ugc-hp-metafield-wrap');
        if (overlaySlot && metafieldWrap && metafieldWrap.innerHTML.trim()) {
          overlayVideo.style.display = 'none';
          var wrap = document.createElement('div');
          wrap.className = 'sl-ugc-hp-overlay-metafield-clone';
          wrap.innerHTML = metafieldWrap.innerHTML;
          overlaySlot.appendChild(wrap);
          var cloneVideo = wrap.querySelector('video');
          if (cloneVideo) { cloneVideo.muted = false; cloneVideo.controls = true; cloneVideo.loop = true; cloneVideo.play().catch(function() {}); }
          var cloneIframe = wrap.querySelector('iframe');
          if (cloneIframe) { cloneIframe.style.width = '100%'; cloneIframe.style.height = '100%'; }
        } else {
          if (productUrl && productUrl !== '#') {
            closeOverlay();
            window.location.href = productUrl;
            return;
          }
          overlayVideo.style.display = '';
          overlayVideo.removeAttribute('src');
        }
      }

      var overlayPhotoLink = document.getElementById('sl-ugc-hp-overlay-photo-link-' + sectionId);
      if (overlayPhotoLink) {
        overlayPhotoLink.href = productUrl && productUrl !== '#' ? productUrl : '#';
        overlayPhotoLink.style.display = productImage ? '' : 'none';
      }
      if (overlayImg) {
        overlayImg.src = productImage;
        overlayImg.alt = productTitle;
      }
      if (overlayName) {
        overlayName.textContent = productTitle;
        overlayName.href = productUrl && productUrl !== '#' ? productUrl : '#';
      }
      var overlayRating = document.getElementById('sl-ugc-hp-overlay-rating-' + sectionId);
      if (overlayRating) {
        var ratingStr = '';
        if (productRating && productReviews) ratingStr = productRating + ' · ' + productReviews;
        else if (productRating) ratingStr = productRating;
        else if (productReviews) ratingStr = productReviews;
        overlayRating.textContent = ratingStr;
        overlayRating.style.display = ratingStr ? '' : 'none';
      }
      if (overlayPrice) overlayPrice.textContent = productPrice;
      if (overlayCompare) {
        overlayCompare.textContent = productCompare;
        overlayCompare.style.display = productCompare ? '' : 'none';
      }
      var overlayAddBtn = document.getElementById('sl-ugc-hp-overlay-add-' + sectionId);
      if (overlayAddBtn) {
        overlayAddBtn.setAttribute('data-variant-id', variantId);
        overlayAddBtn.textContent = ctaText;
        overlayAddBtn.disabled = !variantId;
      }

    }

    function closeOverlay() {
      if (overlay) {
        overlay.setAttribute('hidden', '');
        document.body.style.overflow = '';
      }
      if (overlayVideo) {
        overlayVideo.pause();
        overlayVideo.removeAttribute('src');
        overlayVideo.style.display = '';
      }
      var overlaySlot = document.getElementById('sl-ugc-hp-overlay-video-slot-' + sectionId);
      if (overlaySlot) {
        var cloneContainer = overlaySlot.querySelector('.sl-ugc-hp-overlay-metafield-clone');
        if (cloneContainer) cloneContainer.remove();
      }
      r.querySelectorAll('.sl-ugc-hp-video').forEach(function(v) {
        v.muted = true;
        v.loop = true;
        v.play().catch(function(){});
      });
    }

    loadSwiper(function() {
      if (swiperEl.swiper) return;
      var slidesPerView = window.innerWidth <= 768 ? {{ section.settings.slides_mobile }} : {{ section.settings.slides_desktop }};
      if (typeof Swiper !== 'undefined') {
        try {
          new Swiper(swiperEl, {
            slidesPerView: slidesPerView,
            spaceBetween: {{ section.settings.slide_gap }},
            loop: false,
            breakpoints: {
              320: { slidesPerView: {{ section.settings.slides_mobile }} },
              769: { slidesPerView: {{ section.settings.slides_desktop }} }
            },
            navigation: {
              nextEl: r.querySelector('.swiper-button-next'),
              prevEl: r.querySelector('.swiper-button-prev')
            },
            on: {
              init: function(swiper) {
                playVisibleVideos(swiper);
              },
              slideChangeTransitionEnd: function(swiper) {
                playVisibleVideos(swiper);
              }
            }
          });
        } catch (e) {}
      }
      if (!swiperEl.swiper) {
        var wrapper = swiperEl.querySelector('.swiper-wrapper');
        if (wrapper) {
          swiperEl.style.overflowX = 'auto';
          swiperEl.style.overflowY = 'visible';
          wrapper.style.display = 'flex';
          wrapper.style.gap = '{{ section.settings.slide_gap }}px';
          wrapper.style.flexWrap = 'nowrap';
        }
        var next = r.querySelector('.swiper-button-next');
        var prev = r.querySelector('.swiper-button-prev');
        if (next) next.style.display = 'none';
        if (prev) prev.style.display = 'none';
      }
      r.querySelectorAll('.sl-ugc-hp-card video').forEach(function(v) {
        ensureVideoSrc(v);
        v.muted = true;
        v.loop = true;
        v.play().catch(function(){});
      });

      function refreshCartCount(count) {
        var sel = '.cart-count-bubble, .cart-count, [data-cart-count], .header__icon--cart .count, [data-header-cart-count], .cart-icon__count';
        document.querySelectorAll(sel).forEach(function(el) { el.textContent = count; });
      }
      function updateCartFromSections(sections) {
        if (!sections || typeof sections !== 'object') return;
        for (var id in sections) {
          var html = sections[id];
          if (!html) continue;
          var sel = id.replace(/_/g, '-');
          var el = document.querySelector('[id*="' + sel + '"]') || document.querySelector('[id*="' + id + '"]');
          if (el) el.innerHTML = html;
        }
      }
      function doAjaxAddToCart(variantId, btn) {
        if (!variantId || !btn) return;
        btn.disabled = true;
        if (btn.classList) btn.classList.add('is-loading');
        var origText = btn.textContent;
        btn.textContent = i18nAdd.adding;
        var sectionsToRender = 'cart-icon-bubble,cart-drawer,cart-live-region-text';
        fetch(rootPath.replace(/\/$/, '') + '/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({
            items: [{ id: parseInt(variantId, 10), quantity: 1 }],
            sections: sectionsToRender,
            sections_url: window.location.pathname
          })
        }).then(function(res) { return res.json(); }).then(function(data) {
          if (data.status === 422 || (data.status && data.status >= 400)) throw new Error(data.description || data.message || 'Error');
          if (btn.classList) btn.classList.remove('is-loading');
          btn.textContent = i18nAdd.added;
          if (data.sections) updateCartFromSections(data.sections);
          fetch(rootPath.replace(/\/$/, '') + '/cart.js').then(function(res) { return res.json(); }).then(function(c) { refreshCartCount(c.item_count || 0); }).catch(function() {});
          document.dispatchEvent(new CustomEvent('cart:refresh'));
          if (typeof window.theme !== 'undefined' && window.theme.refreshCart) window.theme.refreshCart();
          setTimeout(function() { btn.disabled = false; btn.textContent = origText; }, 2000);
        }).catch(function() {
          if (btn.classList) btn.classList.remove('is-loading');
          btn.disabled = false;
          btn.textContent = origText;
        });
      }
      r.addEventListener('submit', function(e) {
        var form = e.target;
        if (!form || !form.classList.contains('sl-ugc-hp-add-form')) return;
        e.preventDefault();
        var idInput = form.querySelector('input[name="id"]');
        var variantId = idInput ? idInput.value : '';
        var btn = form.querySelector('.sl-ugc-hp-add-btn');
        doAjaxAddToCart(variantId, btn);
      });
      var overlayAddBtn = document.getElementById('sl-ugc-hp-overlay-add-' + sectionId);
      if (overlayAddBtn) {
        overlayAddBtn.addEventListener('click', function() {
          var vid = overlayAddBtn.getAttribute('data-variant-id');
          doAjaxAddToCart(vid, overlayAddBtn);
        });
      }
      cards.forEach(function(card) {
        card.addEventListener('click', function(e) {
          if (e.target.closest('a') || e.target.closest('form') || e.target.closest('.sl-ugc-hp-add-btn')) return;
          e.preventDefault();
          openOverlay(card);
        });
        card.addEventListener('keydown', function(e) {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openOverlay(card); }
        });
      });

      if (overlayClose) overlayClose.addEventListener('click', closeOverlay);
      overlay.addEventListener('click', function(e) {
        if (e.target === overlay) closeOverlay();
      });
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && overlay && !overlay.hasAttribute('hidden')) closeOverlay();
    });
  }

  function startWhenVisible() {
    var r = document.getElementById('sl-ugc-hp-' + sectionId);
    if (!r) return;
    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function(entries) {
        if (!entries[0].isIntersecting) return;
        io.disconnect();
        run();
      }, { rootMargin: '120px', threshold: 0 });
      io.observe(r);
    } else {
      run();
    }
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', startWhenVisible);
  else startWhenVisible();
})();
</script>
{% endunless %}

