  #sl-ugc-hp-overlay-{{ section.id }} .sl-ugc-hp-overlay-video-slot .sl-ugc-hp-overlay-metafield-clone video {
    border-radius: 30px; width: 100%; display: block;
  }
  #sl-ugc-hp-overlay-{{ section.id }} .sl-ugc-hp-overlay-video-slot .sl-ugc-hp-overlay-metafield-clone iframe {
    width: 100%; aspect-ratio: 9/16; border-radius: 30px; display: block;
