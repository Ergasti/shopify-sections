  #sl-ugc-hp-overlay-{{ section.id }} .sl-ugc-hp-overlay-product .sl-ugc-hp-add-form { margin: 0; flex: 1; min-width: 0; }
  #sl-ugc-hp-{{ section.id }} .sl-ugc-hp-add-btn,
