{% comment %}
  SL - Stacked Offers (Snippet)
  Use when you need BOTH:
   - Repeating bundle deal by collection quantity (e.g. 3 for 299; 6 = 2 deals)
   - Free delivery threshold (cart total, e.g. 650)

  Render:
  {% render 'sl-stacked-offers',
    collection_handle: collection.handle,
    collection_title: collection.title,
    offer_qty: 3,
    offer_price: 299,
    regular_total: 750,
    free_shipping_threshold_amount: 650,
    fill_color_start: '#4ade80',
    fill_color_end: '#16a34a',
    section_id: section.id
  %}
{% endcomment %}

{% assign sid = section_id | default: id | default: block_id | default: 'sl-stacked-offers' %}

{% assign handle = collection_handle | default: '' %}
{% assign title = collection_title | default: handle %}

{% assign offer_qty = offer_qty | default: 3 | plus: 0 %}
{% if offer_qty <= 0 %}{% assign offer_qty = 3 %}{% endif %}

{% assign offer_price_cents = offer_price | default: 299 | plus: 0 | times: 100 %}
{% assign regular_total_cents = regular_total | default: 750 | plus: 0 | times: 100 %}
{% assign savings_cents = regular_total_cents | minus: offer_price_cents %}
{% if savings_cents < 0 %}{% assign savings_cents = 0 %}{% endif %}

{% assign free_shipping_threshold_cents = free_shipping_threshold_amount | default: 650 | plus: 0 | times: 100 %}

{% assign fill_color_start = fill_color_start | default: '#4ade80' | strip %}
{% assign fill_color_end = fill_color_end | default: '#16a34a' | strip %}
{% assign style_variant = style_variant | default: style | default: 'clean' | strip %}
{% assign evergreen_timer_hours = evergreen_timer_hours | default: timer_hours | default: 6 | plus: 0 %}
{% if evergreen_timer_hours <= 0 %}{% assign evergreen_timer_hours = 6 %}{% endif %}
{% assign show_total_saved = show_total_saved | default: true %}
{% if show_total_saved == false or show_total_saved == 'false' %}
  {% assign show_total_saved = false %}
{% else %}
  {% assign show_total_saved = true %}
{% endif %}

{% assign locale_iso = request.locale.iso_code | default: 'en' %}
{% assign is_rtl = false %}
{% if locale_iso == 'ar' or locale_iso == 'he' or locale_iso == 'fa' or locale_iso == 'ur' or locale_iso == 'yi' %}{% assign is_rtl = true %}{% endif %}

{% if handle == blank %}
  {% if request.design_mode %}
    <div style="padding: 16px; border: 1px dashed #ccc; border-radius: 8px; background: #fafafa;">
      <strong>SL - Stacked Offers (Snippet)</strong><br>
      {{ 'sections.sl_stacked_offers.missing_collection' | t | default: 'Pass collection_handle when rendering this snippet.' }}
    </div>
  {% endif %}
{% else %}
  <div
    id="sl-stacked-offers-{{ sid }}"
    class="sl-stacked-offers sl-stacked-offers--{{ style_variant }}{% if is_rtl %} sl-stacked-offers--rtl{% endif %}"
    style="--sl-so-fill-start: {{ fill_color_start }}; --sl-so-fill-end: {{ fill_color_end }};"
    data-sl-stacked-offers
    data-sl-so-collection-handle="{{ handle }}"
    data-sl-so-offer-qty="{{ offer_qty }}"
    data-sl-so-offer-price="{{ offer_price_cents }}"
    data-sl-so-regular-total="{{ regular_total_cents }}"
    data-sl-so-savings="{{ savings_cents }}"
    data-sl-so-free-ship-threshold="{{ free_shipping_threshold_cents }}"
    data-sl-so-currency="{{ cart.currency | default: shop.currency | default: 'EGP' }}"
    data-sl-so-msg-bundle-next="{{ 'sections.sl_stacked_offers.bundle_next' | t | default: 'Add %count% more to unlock the next deal and save %save%.' | escape }}"
    data-sl-so-msg-bundle-earned="{{ 'sections.sl_stacked_offers.bundle_earned' | t | default: 'Unlocked %deals% deal(s). Add %count% more to unlock another and save %save%.' | escape }}"
    data-sl-so-msg-bundle-none="{{ 'sections.sl_stacked_offers.bundle_none' | t | default: 'Add %count% more to unlock your first deal and save %save%.' | escape }}"
    data-sl-so-total_saved="{{ 'sections.sl_stacked_offers.total_saved' | t | default: 'Total saved: %amount%' | escape }}"
    data-sl-so-free_ship_badge="{{ 'sections.sl_stacked_offers.free_ship_badge' | t | default: '+ Free delivery' | escape }}"
    data-sl-so-claimed="{{ 'sections.sl_stacked_offers.claimed' | t | default: 'Claimed %deals% deal(s)' | escape }}"
    data-sl-so-toast-bundle="{{ 'sections.sl_stacked_offers.toast_bundle' | t | default: 'Deal unlocked! You now have %deals% deal(s).' | escape }}"
    data-sl-so-toast-ship="{{ 'sections.sl_stacked_offers.toast_ship' | t | default: 'Free delivery unlocked!' | escape }}"
    data-sl-so-msg-ship-next="{{ 'sections.sl_stacked_offers.ship_next' | t | default: 'Add %amount% more to get free delivery.' | escape }}"
    data-sl-so-msg-ship-earned="{{ 'sections.sl_stacked_offers.ship_earned' | t | default: 'Free delivery unlocked!' | escape }}"
    data-sl-so-msg-ship-tier-almost="{{ 'sections.sl_stacked_offers.ship_tier_almost' | t | default: 'Almost there! Add %amount% more for free delivery.' | escape }}"
    data-sl-so-msg-ship-tier-close="{{ 'sections.sl_stacked_offers.ship_tier_close' | t | default: 'You’re close! Add %amount% more for free delivery.' | escape }}"
    data-sl-so-msg-ship-tier-mid="{{ 'sections.sl_stacked_offers.ship_tier_mid' | t | default: 'Add %amount% more to get free delivery.' | escape }}"
    data-sl-so-msg-ship-tier-far="{{ 'sections.sl_stacked_offers.ship_tier_far' | t | default: 'Free delivery when you add %amount% more.' | escape }}"
    data-sl-so-timer-hours="{{ evergreen_timer_hours }}"
    data-sl-so-timer-label="{{ 'sections.sl_stacked_offers.timer_label' | t | default: 'Ends in' | escape }}"
    data-sl-so-show-total="{{ show_total_saved }}"
    {% if is_rtl %}dir="rtl"{% endif %}
  >
    {{- '' -}}
    {%- comment -%}Corner chips — urgency mode only, absolutely positioned{%- endcomment -%}
    <span class="sl-stacked-offers__badge" aria-hidden="true">
      <span class="sl-stacked-offers__dot"></span>
      {{ 'sections.sl_stacked_offers.urgency' | t | default: 'Stack & save' }}
    </span>
    <span class="sl-stacked-offers__timer" data-sl-so-timer hidden>
      <span data-sl-so-timer-label>{{ 'sections.sl_stacked_offers.timer_label' | t | default: 'Ends in' }}</span>
      <span class="sl-stacked-offers__timer-value" data-sl-so-timer-value>--:--:--</span>
    </span>

    <div class="sl-stacked-offers__inner">

      {%- comment -%}── Hero: deal summary ──{%- endcomment -%}
      <div class="sl-stacked-offers__hero">

        <div class="sl-stacked-offers__headline">
                  <span class="sl-stacked-offers__collection sl-stacked-offers__save">{{ title }}</span>

          <span class="sl-stacked-offers__deal-label">{{ 'sections.sl_stacked_offers.bundle_title' | t | default: 'Buy 3 for' }}</span>
          <span class="sl-stacked-offers__deal-price" data-sl-so-offer-price-text>{{ offer_price_cents | money_without_trailing_zeros }}</span>
                    <span class="sl-stacked-offers__instead">{{ 'sections.sl_stacked_offers.instead_of' | t | default: 'instead of' }}</span>
          <span class="sl-stacked-offers__was" data-sl-so-regular-total-text>{{ regular_total_cents | money_without_trailing_zeros }}</span>
        </div>
        <div class="sl-stacked-offers__was-line">

        </div>
      </div>

      <div class="sl-stacked-offers__sep" aria-hidden="true"></div>

      {%- comment -%}── Bundle progress row ──{%- endcomment -%}
      <div class="sl-stacked-offers__row sl-stacked-offers__row--bundle">
        <div class="sl-stacked-offers__row-head">
          <span class="sl-stacked-offers__row-icon" aria-hidden="true">🧴</span>
          <span class="sl-stacked-offers__row-msg" data-sl-so-bundle-msg>{{ 'sections.sl_stacked_offers.loading' | t | default: 'Checking your cart…' }}</span>
        </div>
        <div class="sl-stacked-offers__track" aria-hidden="true">
          <div class="sl-stacked-offers__fill" data-sl-so-bundle-fill style="--progress:0%">
            <span class="sl-stacked-offers__stripes"></span>
          </div>
        </div>
        <div class="sl-stacked-offers__earned" data-sl-so-earned hidden>
          <span class="sl-stacked-offers__earned-claimed" data-sl-so-earned-claimed></span>
          <span class="sl-stacked-offers__earned-bars" data-sl-so-earned-bars aria-hidden="true"></span>
        </div>
      </div>

      {%- comment -%}── Shipping progress row ──{%- endcomment -%}
      <div class="sl-stacked-offers__row sl-stacked-offers__row--ship" data-sl-so-ship-wrap>
        <div class="sl-stacked-offers__row-head">
          <span class="sl-stacked-offers__row-icon" aria-hidden="true">🚚</span>
          <span class="sl-stacked-offers__row-msg" data-sl-so-ship-msg>{{ 'sections.sl_stacked_offers.loading' | t | default: 'Checking your cart…' }}</span>
        </div>
        <div class="sl-stacked-offers__track" aria-hidden="true">
          <div class="sl-stacked-offers__fill" data-sl-so-ship-fill style="--progress:0%">
            <span class="sl-stacked-offers__stripes"></span>
          </div>
        </div>
      </div>

      {%- comment -%}── Total saved — CSS hides when text is empty ──{%- endcomment -%}
      {% if show_total_saved %}
      <div class="sl-stacked-offers__savings-row" data-sl-so-earned-total-row>
        <div class="sl-stacked-offers__savings" data-sl-so-earned-total>
          <span class="sl-stacked-offers__savings-icon" aria-hidden="true">💰</span>
          <span data-sl-so-earned-total-text></span>
        </div>
      </div>
      {% endif %}

    </div>

    <div class="sl-stacked-offers__toast" data-sl-so-toast aria-live="polite" aria-atomic="true"></div>
  </div>

  <style>
    /* ── Card ─────────────────────────────────────────────── */
    #sl-stacked-offers-{{ sid }}.sl-stacked-offers {
      --sl-so-accent-light: rgba(22,163,74,.10);
      --sl-so-accent-mid:   rgba(22,163,74,.22);
      --sl-so-text:         #111827;
      --sl-so-text-2:       #374151;
      --sl-so-text-3:       #6b7280;
      --sl-so-border:       rgba(15,23,42,.09);
      width: 100%;
      max-width: 560px;
      margin: 16px auto;
      background: #ffffff;
      border-radius: 16px;
      border: 1.5px solid var(--sl-so-border);
      box-shadow: 0 1px 4px rgba(15,23,42,.06), 0 6px 20px rgba(15,23,42,.09);
      overflow: hidden;
      position: relative;
      font-family: var(--font-body-family, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif);
      font-size: 14px;
      color: var(--sl-so-text);
    }
    #sl-stacked-offers-{{ sid }}.sl-stacked-offers--urgency {
      border-color: rgba(22,163,74,.28);
      box-shadow: 0 1px 4px rgba(15,23,42,.06), 0 8px 28px rgba(15,23,42,.12), 0 0 0 3px rgba(22,163,74,.09);
      animation: sl-so-card-glow 3s ease-in-out infinite;
    }
    @keyframes sl-so-card-glow {
      0%,100% { box-shadow: 0 1px 4px rgba(15,23,42,.06), 0 8px 28px rgba(15,23,42,.12), 0 0 0 3px rgba(22,163,74,.09); }
      50%      { box-shadow: 0 1px 4px rgba(15,23,42,.06), 0 8px 28px rgba(15,23,42,.14), 0 0 0 5px rgba(22,163,74,.18); }
    }
    /* ── Corner chips (urgency only) ─────────────────────── */
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__badge { display: none; }
    #sl-stacked-offers-{{ sid }}.sl-stacked-offers--urgency .sl-stacked-offers__badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      position: absolute;
      top: 10px;
      inset-inline-start: 12px;
      z-index: 2;
      padding: 3px 10px;
      border-radius: 999px;
      background: rgba(15,23,42,.06);
      border: 1px solid rgba(15,23,42,.12);
      color: #0f172a;
      font-size: .72rem;
      font-weight: 700;
      letter-spacing: .06em;
      text-transform: uppercase;
      white-space: nowrap;
    }
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      background: #22c55e;
      flex-shrink: 0;
      animation: sl-so-dot-ping 1.4s ease-in-out infinite;
    }
    @keyframes sl-so-dot-ping {
      0%,100% { box-shadow: 0 0 0 0 rgba(34,197,94,.5); }
      50%      { box-shadow: 0 0 0 4px rgba(34,197,94,0); }
    }
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__timer { display: none !important; }
    #sl-stacked-offers-{{ sid }}.sl-stacked-offers--urgency .sl-stacked-offers__timer {
      display: inline-flex !important;
      align-items: center;
      gap: 5px;
      position: absolute;
      top: 10px;
      inset-inline-end: 12px;
      z-index: 2;
      padding: 3px 10px;
      border-radius: 999px;
      background: rgba(22,163,74,.12);
      border: 1px solid rgba(22,163,74,.26);
      color: #14532d;
      font-size: .72rem;
      font-weight: 700;
      letter-spacing: .02em;
      white-space: nowrap;
    }
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__timer-value {
      font-variant-numeric: tabular-nums; font-weight: 800;
    }
    /* ── Inner layout ─────────────────────────────────────── */
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__inner { display: flex; flex-direction: column; }
    #sl-stacked-offers-{{ sid }}.sl-stacked-offers--urgency .sl-stacked-offers__inner { padding-top: 36px; }
    /* ── Hero ─────────────────────────────────────────────── */
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__hero {
      padding: 16px 18px 14px;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__hero-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 2px;
    }
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__collection {
      font-size: .72rem;
      font-weight: 700;
      color: var(--sl-so-text-3);
      text-transform: uppercase;
      letter-spacing: .08em;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__save {
      display: inline-flex;
      align-items: center;
      gap: 3px;
      padding: 3px 10px;
      border-radius: 999px;
      background: var(--sl-so-accent-light);
      border: 1.5px solid var(--sl-so-accent-mid);
      color: #15803d;
      font-size: .78rem;
      font-weight: 700;
      white-space: nowrap;
      flex-shrink: 0;
    }
    #sl-stacked-offers-{{ sid }}.sl-stacked-offers--urgency .sl-stacked-offers__save {
      background: linear-gradient(135deg, rgba(34,197,94,.16), rgba(250,204,21,.12));
      border-color: rgba(34,197,94,.35);
      animation: sl-so-save-bounce 2s ease-in-out infinite;
    }
    @keyframes sl-so-save-bounce { 0%,100% { transform: scale(1); } 50% { transform: scale(1.05); } }
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__headline {
      display: flex;
      align-items: baseline;
      gap: 6px;
      flex-wrap: wrap;
    }
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__deal-label {
      font-size: 1.18rem;
      font-weight: 700;
      color: var(--sl-so-text);
      line-height: 1.25;
    }
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__deal-price {
      font-size: 1.35rem;
      font-weight: 800;
      color: #16a34a;
      line-height: 1.25;
      white-space: nowrap;
    }
    #sl-stacked-offers-{{ sid }}.sl-stacked-offers--urgency .sl-stacked-offers__deal-price { font-size: 1.42rem; }
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__was-line { display: flex; align-items: center; gap: 4px; }
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__instead,
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__was { font-size: .82rem; color: var(--sl-so-text-3); }
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__was { text-decoration: line-through; }
    /* ── Separator ────────────────────────────────────────── */
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__sep { height: 1px; background: var(--sl-so-border); margin: 0 18px; }
    /* ── Progress rows ────────────────────────────────────── */
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__row {
      padding: 14px 18px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__row + .sl-stacked-offers__row {
      border-top: 1px solid var(--sl-so-border);
    }
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__row-head { display: flex; align-items: flex-start; gap: 8px; }
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__row-icon { font-size: 1rem; line-height: 1.4; flex-shrink: 0; }
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__row-msg {
      font-size: .88rem;
      font-weight: 600;
      color: var(--sl-so-text-2);
      line-height: 1.4;
      text-align: start;
    }
    #sl-stacked-offers-{{ sid }}.sl-stacked-offers--urgency .sl-stacked-offers__row-msg {
      font-weight: 700; color: var(--sl-so-text);
    }
    /* ── Progress bar ─────────────────────────────────────── */
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__track {
      position: relative;
      width: 100%;
      height: 9px;
      background: rgba(15,23,42,.07);
      border-radius: 10px;
      overflow: hidden;
    }
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__fill {
      position: absolute;
      inset: 0;
      width: var(--progress, 0%);
      height: 100%;
      background: linear-gradient(90deg, var(--sl-so-fill-start,#4ade80), var(--sl-so-fill-end,#16a34a));
      border-radius: 10px;
      transition: width .5s cubic-bezier(.2,.8,.2,1);
      overflow: hidden;
    }
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__stripes {
      position: absolute; inset: 0;
      background-image: linear-gradient(
        45deg,
        rgba(255,255,255,.28) 25%, transparent 25%,
        transparent 50%, rgba(255,255,255,.28) 50%,
        rgba(255,255,255,.28) 75%, transparent 75%
      );
      background-size: 12px 12px;
      animation: sl-so-stripes .8s linear infinite;
    }
    @keyframes sl-so-stripes { from { background-position: 0 0; } to { background-position: 12px 0; } }
    /* ── Earned state (inside bundle row) ────────────────── */
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__earned {
      display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
    }
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__earned-claimed {
      display: inline-flex;
      align-items: center;
      padding: 2px 8px;
      border-radius: 999px;
      background: var(--sl-so-accent-light);
      border: 1px solid var(--sl-so-accent-mid);
      color: #15803d;
      font-size: .75rem;
      font-weight: 700;
      white-space: nowrap;
    }
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__earned-bars { display: flex; gap: 4px; align-items: center; flex-wrap: wrap; }
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__earned-bar {
      width: 26px; height: 5px;
      border-radius: 999px;
      background: linear-gradient(90deg, var(--sl-so-fill-start,#4ade80), var(--sl-so-fill-end,#16a34a));
      opacity: .9;
    }
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__earned-more {
      font-size: .72rem; font-weight: 700; color: var(--sl-so-text-3);
      background: rgba(15,23,42,.05); border: 1px solid var(--sl-so-border);
      padding: 1px 6px; border-radius: 999px;
    }
    /* ── Savings row (CSS hides when text empty) ─────────── */
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__savings-row {
      border-top: 1px solid var(--sl-so-border);
      padding: 12px 18px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__savings-row:has([data-sl-so-earned-total-text]:empty) { display: none; }
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__savings {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 5px 14px;
      border-radius: 999px;
      background: var(--sl-so-accent-light);
      border: 1.5px solid var(--sl-so-accent-mid);
      color: #15803d;
      font-size: .85rem;
      font-weight: 700;
    }
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__savings-icon { font-size: .95rem; line-height: 1; }
    /* ── Toast ────────────────────────────────────────────── */
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__toast {
      position: fixed;
      inset-inline: 16px;
      bottom: 16px;
      z-index: 99999;
      max-width: 520px;
      margin-inline: auto;
      padding: 12px 16px;
      border-radius: 12px;
      background: rgba(15,23,42,.92);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      color: #fff;
      font-size: .9rem;
      font-weight: 600;
      letter-spacing: .01em;
      box-shadow: 0 12px 36px rgba(0,0,0,.24);
      transform: translateY(16px);
      opacity: 0;
      pointer-events: none;
      transition: transform 260ms cubic-bezier(.2,.8,.2,1), opacity 260ms ease;
      text-align: start;
    }
    #sl-stacked-offers-{{ sid }} .sl-stacked-offers__toast.is-active { transform: translateY(0); opacity: 1; }
    /* ── Reduce motion ────────────────────────────────────── */
    @media (prefers-reduced-motion: reduce) {
      #sl-stacked-offers-{{ sid }} .sl-stacked-offers__fill,
      #sl-stacked-offers-{{ sid }} .sl-stacked-offers__stripes,
      #sl-stacked-offers-{{ sid }} .sl-stacked-offers__dot,
      #sl-stacked-offers-{{ sid }}.sl-stacked-offers--urgency,
      #sl-stacked-offers-{{ sid }}.sl-stacked-offers--urgency .sl-stacked-offers__save,
      #sl-stacked-offers-{{ sid }} .sl-stacked-offers__toast {
        animation: none !important; transition: none !important;
      }
    }
  </style>

  <script>
  (function() {
    var root = document.getElementById('sl-stacked-offers-{{ sid }}');
    if (!root) return;

    var cache = window.__slStackedOffersCollectionCache = window.__slStackedOffersCollectionCache || {};
    var prevDeals = null;
    var prevShipReached = null;
    var toastTimer = null;
    var countdownInterval = null;

    function timerKey() {
      var handle = root.getAttribute('data-sl-so-collection-handle') || 'collection';
      var hours = root.getAttribute('data-sl-so-timer-hours') || '6';
      return 'sl_so_timer_end_' + handle + '_' + hours;
    }

    function ensureTimerEndMs() {
      var hours = parseInt(root.getAttribute('data-sl-so-timer-hours') || '6', 10) || 6;
      var key = timerKey();
      var now = Date.now();
      var stored = null;
      try { stored = window.sessionStorage ? window.sessionStorage.getItem(key) : null; } catch (e) {}
      var endMs = stored ? parseInt(stored, 10) : 0;
      if (!endMs || endMs < now) {
        endMs = now + (hours * 60 * 60 * 1000);
        try { if (window.sessionStorage) window.sessionStorage.setItem(key, String(endMs)); } catch (e2) {}
      }
      return endMs;
    }

    function formatHMS(ms) {
      var total = Math.max(0, Math.floor(ms / 1000));
      var h = Math.floor(total / 3600);
      var m = Math.floor((total % 3600) / 60);
      var s = total % 60;
      function pad(n) { return (n < 10 ? '0' : '') + String(n); }
      return pad(h) + ':' + pad(m) + ':' + pad(s);
    }

    function startEvergreenTimer() {
      if (!root.classList.contains('sl-stacked-offers--urgency')) return;
      var wrap = root.querySelector('[data-sl-so-timer]');
      var valueEl = root.querySelector('[data-sl-so-timer-value]');
      var labelEl = root.querySelector('[data-sl-so-timer-label]');
      if (!wrap || !valueEl) return;
      wrap.hidden = false;
      if (labelEl) labelEl.textContent = root.getAttribute('data-sl-so-timer-label') || labelEl.textContent || '';

      if (countdownInterval) window.clearInterval(countdownInterval);
      var endMs = ensureTimerEndMs();
      countdownInterval = window.setInterval(function() {
        var now = Date.now();
        if (now >= endMs) {
          endMs = ensureTimerEndMs();
        }
        valueEl.textContent = formatHMS(endMs - now);
      }, 250);
    }

    function showToast(message) {
      var toast = root.querySelector('[data-sl-so-toast]');
      if (!toast) return;
      if (toastTimer) window.clearTimeout(toastTimer);
      toast.textContent = message;
      toast.classList.add('is-active');
      toastTimer = window.setTimeout(function() {
        toast.classList.remove('is-active');
      }, 3200);
    }

    var CONFETTI_SCRIPT = 'https://cdn.jsdelivr.net/npm/@hiseb/confetti@2.1.0/dist/confetti.min.js';
    var confettiLoaded = false;

    function shootConfetti() {
      if (typeof window.confetti !== 'function') return;
      var positions = [
        { x: window.innerWidth * 0.5, y: window.innerHeight * 0.5 },
        { x: window.innerWidth * 0.25, y: window.innerHeight * 0.4 },
        { x: window.innerWidth * 0.75, y: window.innerHeight * 0.35 }
      ];
      for (var i = 0; i < positions.length; i++) {
        (function(pos, idx) {
          setTimeout(function() {
            window.confetti({ position: { x: pos.x, y: pos.y }, count: 80, size: 1.2, velocity: 220, fade: true });
          }, idx * 250);
        })(positions[i], i);
      }
    }

    function playConfetti() {
      if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      function run() { shootConfetti(); setTimeout(shootConfetti, 150); setTimeout(shootConfetti, 300); }
      if (typeof window.confetti === 'function') { run(); return; }
      if (confettiLoaded) return;
      confettiLoaded = true;
      var s = document.createElement('script');
      s.src = CONFETTI_SCRIPT;
      s.onload = run;
      document.head.appendChild(s);
    }

    function formatMoneyNoDecimals(cents, currency) {
      cents = Math.max(0, cents || 0);
      currency = (currency || '').toUpperCase() || 'EGP';
      try {
        if (window.Shopify && typeof window.Shopify.formatMoney === 'function') {
          var fmt = window.money_format || window.Shopify.money_format || '${{amount}}';
          var fmtNoDecimals = fmt
            .replace('amount_with_comma_separator', 'amount_no_decimals_with_comma_separator')
            .replace('amount_with_period_and_space_separator', 'amount_no_decimals_with_period_and_space_separator')
            .replace('amount_with_space_separator', 'amount_no_decimals_with_space_separator')
            .replace('amount_with_apostrophe_separator', 'amount_no_decimals_with_apostrophe_separator')
            .replace('amount', 'amount_no_decimals');
          return window.Shopify.formatMoney(cents, fmtNoDecimals);
        }
      } catch (e) {}
      try {
        return new Intl.NumberFormat(undefined, { style: 'currency', currency: currency, minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(cents / 100);
      } catch (e2) {}
      return String(Math.round(cents / 100));
    }

    function fetchCollectionIds(handle) {
      if (!handle) return Promise.resolve({});
      if (cache[handle] && cache[handle].promise) return cache[handle].promise;

      var ids = {};
      var page = 1;
      var maxPages = 10;

      function loadNext() {
        var url = '/collections/' + encodeURIComponent(handle) + '/products.json?limit=250&page=' + page;
        return fetch(url, { credentials: 'same-origin' })
          .then(function(r) { return r.json(); })
          .then(function(data) {
            var products = data && data.products ? data.products : [];
            for (var i = 0; i < products.length; i++) {
              if (products[i] && products[i].id) ids[String(products[i].id)] = true;
            }
            if (!products.length || page >= maxPages) return ids;
            page += 1;
            return loadNext();
          });
      }

      cache[handle] = cache[handle] || {};
      cache[handle].promise = loadNext().catch(function() { return ids; });
      return cache[handle].promise;
    }

    function fetchCart() {
      return fetch('/cart.js', { credentials: 'same-origin' }).then(function(r) { return r.json(); });
    }

    function qtyForIds(cart, idsMap) {
      if (!cart || !cart.items || !cart.items.length) return 0;
      var sum = 0;
      for (var i = 0; i < cart.items.length; i++) {
        var it = cart.items[i];
        if (idsMap && idsMap[String(it.product_id)] === true) sum += (it.quantity || 0);
      }
      return sum;
    }

    function setProgress(el, pct) {
      if (!el) return;
      el.style.setProperty('--progress', pct + '%');
      el.style.width = pct + '%';
    }

    function update(cart, idsMap) {
      var offerQty = parseInt(root.getAttribute('data-sl-so-offer-qty') || '3', 10) || 3;
      var savings = parseInt(root.getAttribute('data-sl-so-savings') || '0', 10) || 0;
      var shipThreshold = parseInt(root.getAttribute('data-sl-so-free-ship-threshold') || '0', 10) || 0;
      var currency = (cart && cart.currency) ? cart.currency : (root.getAttribute('data-sl-so-currency') || 'EGP');
      try { root.setAttribute('data-sl-so-currency', currency); } catch (e0) {}

      var qty = qtyForIds(cart, idsMap);
      var deals = offerQty > 0 ? Math.floor(qty / offerQty) : 0;
      var remainder = offerQty > 0 ? (qty % offerQty) : 0;
      var nextCount = remainder === 0 ? offerQty : (offerQty - remainder);
      var bundlePct = offerQty > 0 ? Math.min(100, (remainder / offerQty) * 100) : 0;

      var bundleMsgEl = root.querySelector('[data-sl-so-bundle-msg]');
      var bundleFill = root.querySelector('[data-sl-so-bundle-fill]');
      if (bundleMsgEl) {
        var tplNone = root.getAttribute('data-sl-so-msg-bundle-none') || '';
        var tplEarned = root.getAttribute('data-sl-so-msg-bundle-earned') || '';
        var tplNext = root.getAttribute('data-sl-so-msg-bundle-next') || '';
        var msg;
        if (deals <= 0) {
          msg = tplNone;
        } else if (remainder > 0) {
          msg = tplNext;
        } else {
          msg = tplEarned;
        }
        bundleMsgEl.textContent = msg
          .replace(/%deals%/g, String(deals))
          .replace(/%count%/g, String(nextCount))
          .replace(/%save%/g, formatMoneyNoDecimals(savings, currency));
      }
      setProgress(bundleFill, bundlePct);

      var earnedWrap = root.querySelector('[data-sl-so-earned]');
      var earnedBars = root.querySelector('[data-sl-so-earned-bars]');
      var earnedClaimed = root.querySelector('[data-sl-so-earned-claimed]');
      var earnedTotalText = root.querySelector('[data-sl-so-earned-total-text]');
      var showTotal = String(root.getAttribute('data-sl-so-show-total')).toLowerCase() !== 'false';
      if (earnedWrap && earnedBars && earnedClaimed) {
        if (deals > 0) {
          earnedWrap.hidden = false;
          var maxBars = 5;
          var barsToShow = Math.min(maxBars, deals);
          var extra = deals - barsToShow;
          var html = '';
          for (var b = 0; b < barsToShow; b++) html += '<span class=\"sl-stacked-offers__earned-bar\"></span>';
          if (extra > 0) html += '<span class=\"sl-stacked-offers__earned-more\">+' + extra + '</span>';
          earnedBars.innerHTML = html;

          var claimedTpl = root.getAttribute('data-sl-so-claimed') || '';
          earnedClaimed.textContent = claimedTpl ? claimedTpl.replace(/%deals%/g, String(deals)) : '';

          var totalSavedCents = deals * savings;
          var tplTotal = root.getAttribute('data-sl-so-total_saved') || 'Total saved: %amount%';
          if (earnedTotalText) {
            earnedTotalText.textContent = showTotal ? tplTotal.replace(/%amount%/g, formatMoneyNoDecimals(totalSavedCents, currency)) : '';
          }
        } else {
          earnedWrap.hidden = true;
          earnedBars.innerHTML = '';
          earnedClaimed.textContent = '';
          if (earnedTotalText) earnedTotalText.textContent = '';
        }
      }

      var total = cart && typeof cart.total_price === 'number' ? cart.total_price : 0;
      var shipWrap = root.querySelector('[data-sl-so-ship-wrap]');
      if (shipWrap) {
        if (total <= 0) shipWrap.style.display = 'none';
        else shipWrap.style.display = '';
      }
      var remainingShip = Math.max(0, shipThreshold - total);
      var shipPct = shipThreshold > 0 ? Math.min(100, (total / shipThreshold) * 100) : 0;
      var shipReached = remainingShip <= 0;
      var shipMsgEl = root.querySelector('[data-sl-so-ship-msg]');
      var shipFill = root.querySelector('[data-sl-so-ship-fill]');
      if (shipMsgEl) {
        if (shipReached) {
          shipMsgEl.textContent = root.getAttribute('data-sl-so-msg-ship-earned') || '';
        } else {
          var TIER_ALMOST_CENTS = 1000;
          var TIER_CLOSE_CENTS = 3000;
          var TIER_MID_CENTS = 5000;

          var tplShip = root.getAttribute('data-sl-so-msg-ship-next') || '';
          if (remainingShip < TIER_ALMOST_CENTS) {
            tplShip = root.getAttribute('data-sl-so-msg-ship-tier-almost') || tplShip;
          } else if (remainingShip < TIER_CLOSE_CENTS) {
            tplShip = root.getAttribute('data-sl-so-msg-ship-tier-close') || tplShip;
          } else if (remainingShip < TIER_MID_CENTS) {
            tplShip = root.getAttribute('data-sl-so-msg-ship-tier-mid') || tplShip;
          } else {
            tplShip = root.getAttribute('data-sl-so-msg-ship-tier-far') || tplShip;
          }
          shipMsgEl.textContent = tplShip.replace(/%amount%/g, formatMoneyNoDecimals(remainingShip, currency));
        }
      }
      setProgress(shipFill, shipPct);

      var earnedWrap = root.querySelector('[data-sl-so-earned]');
      var earnedTotalText = root.querySelector('[data-sl-so-earned-total-text]');
      var showTotal = String(root.getAttribute('data-sl-so-show-total')).toLowerCase() !== 'false';
      if (showTotal && earnedWrap && !earnedWrap.hidden && earnedTotalText && deals > 0 && shipReached) {
        var badge = root.getAttribute('data-sl-so-free_ship_badge') || '';
        if (badge) earnedTotalText.textContent = earnedTotalText.textContent + ' ' + badge;
      }

      var didEarnDeal = (prevDeals != null) && (deals > prevDeals);
      var didReachShip = (prevShipReached != null) && (shipReached && !prevShipReached);
      prevDeals = deals;
      prevShipReached = shipReached;
      if (didEarnDeal || didReachShip) playConfetti();

      if (didEarnDeal) {
        var tplToastBundle = root.getAttribute('data-sl-so-toast-bundle') || '';
        if (tplToastBundle) showToast(tplToastBundle.replace(/%deals%/g, String(deals)));
      } else if (didReachShip) {
        var tplToastShip = root.getAttribute('data-sl-so-toast-ship') || '';
        if (tplToastShip) showToast(tplToastShip);
      }
    }

    function refresh() {
      var handle = root.getAttribute('data-sl-so-collection-handle');
      return fetchCollectionIds(handle)
        .then(function(idsMap) { return fetchCart().then(function(cart) { update(cart, idsMap); }); })
        .catch(function() {});
    }

    refresh();
    startEvergreenTimer();
    ['cart:refresh','cart:change','cart:updated','product:added'].forEach(function(name){
      document.addEventListener(name, function(e){
        var detail = e && e.detail ? e.detail : null;
        var cart = detail && (detail.cart || detail);
        if (!cart) { setTimeout(refresh, 120); return; }
        var handle = root.getAttribute('data-sl-so-collection-handle');
        fetchCollectionIds(handle).then(function(idsMap){ update(cart, idsMap); }).catch(function(){ update(cart, {}); });
      });
    });

    var _fetch = window.fetch;
    if (typeof _fetch === 'function') {
      window.fetch = function() {
        var url = (arguments[0] && arguments[0].url) ? arguments[0].url : arguments[0];
        var watches = typeof url === 'string' && (
          url.indexOf('/cart/add') !== -1 ||
          url.indexOf('/cart/change') !== -1 ||
          url.indexOf('/cart/update') !== -1 ||
          url.indexOf('/cart/clear') !== -1
        );
        return _fetch.apply(this, arguments).then(function(res) {
          if (watches) setTimeout(refresh, 150);
          return res;
        });
      };
    }
  })();
  </script>
{% endif %}

