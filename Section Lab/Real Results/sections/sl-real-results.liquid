{% comment %}
  SL - Real Results (Results you'll see)
  Accordion with "how it affects" boxes: video, title, bubbles (pills with checkmark), description.
  Block-based: add "Result box" blocks with video URL, title, bubbles, description.
  Optional: product metafield custom.real_results_highlights for product-specific content (first entry used).
{% endcomment %}

{% assign accordion_heading = section.settings.accordion_heading | default: "RESULTS YOU'LL SEE" %}
{% assign has_blocks = false %}
{% if section.blocks.size > 0 %}
  {% assign has_blocks = true %}
{% endif %}
{% assign highlights = product.metafields.custom.real_results_highlights.value | default: product.metafields.custom.real_results_highlights | default: nil %}
{% if product != blank and highlights != blank and highlights.size > 0 and has_blocks == false %}
  {% assign has_blocks = true %}
{% endif %}

{% unless has_blocks %}
  {% if request.design_mode %}
    <div id="sl-rr-section-{{ section.id }}" class="sl-rr-root" style="padding: 24px; text-align: center; background: #fff;">
      <p style="margin: 0; color: #666;">{{ 'sections.sl_real_results.no_highlights' | t }}</p>
    </div>
  {% endif %}
{% else %}
{% assign rr_id = section.id %}
<div id="sl-rr-section-{{ rr_id }}" class="sl-rr-root sl-rr-accordion">
  <details class="accordion group" is="accordion-disclosure" aria-expanded="true" {% if section.settings.accordion_open %}open{% endif %}>
    <summary>
      <span class="accordion__toggle h6">
        <span>{{ accordion_heading }}</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="12" height="8" viewBox="0 0 12 8" fill="none" class="group-expanded:rotate icon icon-wd-arrow" aria-hidden="true">
          <path d="M11 1L6 7L1 1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
    </summary>
    <div class="accordion__content prose">
      <div class="how-it-affects-container sl-rr-how-it-affects">
        {% if section.blocks.size > 0 %}
          {% for block in section.blocks %}
            {% if block.type == 'result_box' %}
              <div class="how-it-affects-box" {{ block.shopify_attributes }}>
                <div class="affect-image" data-sl-rr-video-trigger>
                  {% if block.settings.video_url != blank %}
                    <video playsinline muted autoplay loop width="100%" class="sl-rr-video" data-sl-rr-video>
                      <source src="{{ block.settings.video_url }}" type="video/mp4">
                    </video>
                  {% elsif block.settings.image != blank %}
                    <img src="{{ block.settings.image | image_url: width: 600, height: 600 }}" alt="" width="600" height="600" loading="lazy" class="sl-rr-poster" style="width: 100%; height: auto;">
                  {% else %}
                    <div class="sl-rr-placeholder" style="aspect-ratio: 1; background: #f4f0e9; border-radius: 12px;"></div>
                  {% endif %}
                </div>
                <div class="how-it-affect-text-box">
                  {% if block.settings.title != blank %}
                    <p class="title">{{ block.settings.title }}</p>
                  {% endif %}
                  {% assign bubbles_text = block.settings.bubbles | strip %}
                  {% if bubbles_text != blank %}
                    {% assign bubbles_normalized = bubbles_text | replace: ', ', '
' | replace: ',', '
' %}
                    {% assign bubbles_list = bubbles_normalized | newline_to_br | split: '<br />' %}
                    <p class="bubles">
                      {% for b in bubbles_list %}
                        {% assign b_strip = b | strip %}
                        {% if b_strip != '' %}
                          <span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="12" height="9" viewBox="0 0 12 9" fill="none" aria-hidden="true"><path d="M1 4.53651L4.04336 7.6L10.6 1" stroke="#7D8F3E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            {{ b_strip }}
                          </span>
                        {% endif %}
                      {% endfor %}
                    </p>
                  {% endif %}
                  {% if block.settings.description != blank %}
                    <p class="description">{{ block.settings.description }}</p>
                  {% endif %}
                </div>
              </div>
            {% endif %}
          {% endfor %}
        {% else %}
          {% comment %} Fallback: first product highlight from metafield {% endcomment %}
          {% assign entry = highlights[0] %}
          {% assign title = entry.title | default: entry.headline %}
          <div class="how-it-affects-box">
            <div class="affect-image" data-sl-rr-video-trigger>
              {% if entry.video != blank %}
                <video playsinline muted autoplay loop width="100%" class="sl-rr-video" data-sl-rr-video>
                  <source src="{{ entry.video.sources[0].url | default: entry.video }}" type="video/mp4">
                </video>
              {% elsif entry.image != blank %}
                <img src="{{ entry.image | image_url: width: 600, height: 600 }}" alt="" width="600" height="600" loading="lazy" class="sl-rr-poster" style="width: 100%; height: auto;">
              {% else %}
                <div class="sl-rr-placeholder" style="aspect-ratio: 1; background: #f4f0e9; border-radius: 12px;"></div>
              {% endif %}
            </div>
            <div class="how-it-affect-text-box">
              {% if title != blank %}<p class="title">{{ title }}</p>{% endif %}
              {% if entry.description != blank %}<p class="description">{{ entry.description }}</p>{% endif %}
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </details>
</div>

<style>
  #sl-rr-section-{{ rr_id }} .accordion__toggle { display: inline-flex; align-items: center; gap: 8px; cursor: pointer; }
  #sl-rr-section-{{ rr_id }} .accordion .icon { transition: transform 0.2s; }
  #sl-rr-section-{{ rr_id }} .accordion[open] .icon { transform: rotate(180deg); }
  #sl-rr-section-{{ rr_id }} .how-it-affects-container { border-radius: 16px; border: 0.5px solid #EBEBEB; background: #FFF; box-shadow: 0 4px 4px -1px rgba(0, 0, 0, 0.02); padding: 20px; }
  #sl-rr-section-{{ rr_id }} .how-it-affects-container .flex { display: flex; align-items: center; gap: 5px; margin-block-start: 0; padding-top: 4px; }
  #sl-rr-section-{{ rr_id }} .how-it-affects-container p.title { color: #272E0F; font-size: 14px; font-style: normal; font-weight: 600; line-height: 140%; letter-spacing: 0.16px; margin: 0 0 10px 0; }
  #sl-rr-section-{{ rr_id }} .affect-image { position: relative; cursor: pointer; }
  #sl-rr-section-{{ rr_id }} .how-it-affects-container p.bubles { margin-block-start: 10px; margin: 10px 0 0 0; }
  #sl-rr-section-{{ rr_id }} .how-it-affects-container p.bubles span { border-radius: 28px; background: #F4F0E9; display: inline-flex; padding: 2px 4px; align-items: center; gap: 4px; width: max-content; margin-right: 6px; margin-bottom: 4px; color: #878787; font-size: 13px; font-weight: 400; line-height: normal; letter-spacing: 0.13px; }
  #sl-rr-section-{{ rr_id }} .how-it-affects-container .how-it-affects-box { display: grid; gap: 16px; }
  #sl-rr-section-{{ rr_id }} .how-it-affects-container .how-it-affects-box svg { display: inline; vertical-align: middle; }
  #sl-rr-section-{{ rr_id }} .how-it-affects-container .how-it-affect-text-box .description { color: #272E0F; font-size: 14px; font-weight: 400; line-height: 150%; letter-spacing: 0.28px; margin-block-start: 10px; margin: 10px 0 0 0; }
  #sl-rr-section-{{ rr_id }} .how-it-affect-text-box { margin-block-start: 0 !important; }
  #sl-rr-section-{{ rr_id }} .how-it-affects-container video { border-radius: 13px; display: block; }
  #sl-rr-section-{{ rr_id }} .how-it-affects-container .sl-rr-poster { border-radius: 13px; }
  #sl-rr-section-{{ rr_id }} .accordion__content { margin-top: 12px; }
  #sl-rr-section-{{ rr_id }} .accordion__content.prose :first-child { margin-block-start: 0 !important; }
  #sl-rr-section-{{ rr_id }} .accordion__content.prose :last-child { margin-block-end: 0 !important; }
</style>

<script>
(function() {
  var root = document.getElementById('sl-rr-section-{{ rr_id }}');
  if (!root) return;
  root.querySelectorAll('[data-sl-rr-video-trigger]').forEach(function(trigger) {
    var video = trigger.querySelector('[data-sl-rr-video]');
    if (video) {
      trigger.addEventListener('click', function() {
        video.classList.toggle('active');
        if (video.classList.contains('active')) {
          video.play && video.play();
        } else {
          video.pause && video.pause();
        }
      });
    }
  });
})();
</script>
{% endunless %}

{% schema %}
{
  "name": "SL - Real Results",
  "tag": "section",
  "class": "sl-real-results-section",
  "settings": [
    {
      "type": "text",
      "id": "accordion_heading",
      "label": "Accordion heading",
      "default": "RESULTS YOU'LL SEE"
    },
    {
      "type": "checkbox",
      "id": "accordion_open",
      "label": "Open by default",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "result_box",
      "name": "Result box",
      "settings": [
        {
          "type": "url",
          "id": "video_url",
          "label": "Video URL"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image (if no video)",
          "info": "Shown when Video URL is blank"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Instant glow, silky-soft skin"
        },
        {
          "type": "textarea",
          "id": "bubbles",
          "label": "Bubbles (one per line)",
          "default": "Pearly Shimmer\nFast-Absorbing\nNon-Greasy Feel",
          "info": "One bubble tag per line"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Designed to hydrate and leave a subtle, sun-kissed sheen that melts into skin."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SL - Real Results",
      "category": "Content",
      "blocks": [
        {
          "type": "result_box",
          "settings": {
            "title": "Instant glow, silky-soft skin",
            "bubbles": "Pearly Shimmer\nFast-Absorbing\nNon-Greasy Feel",
            "description": "Designed to hydrate and leave a subtle, sun-kissed sheen that melts into skin."
          }
        }
      ]
    }
  ],
  "templates": ["product"]
}
{% endschema %}
