{% comment %}
  SL - Real Results (Snippet) — "Results you'll see" accordion + how-it-affects box.
  Usage: {% render 'sl-real-results', product: product, block_id: block.id %}
  Optional: debug: true — show debug panel. accordion_heading, accordion_open.
  Uses first entry from product.metafields.custom.real_results_highlights (Product Highlight: title, description, image, video, bubbles).
{% endcomment %}

{% assign block_id = block_id | default: 'rr' %}
{% assign prod = product | default: nil %}
{% assign show_debug = debug | default: false %}
{% if request.design_mode %}{% assign show_debug = true %}{% endif %}

{% assign highlights = prod.metafields.custom.real_results_highlights.value | default: prod.metafields.custom.real_results_highlights | default: nil %}
{% assign has_content = false %}
{% assign entry = nil %}
{% assign rr_title = '' %}
{% assign rr_description = '' %}
{% assign rr_image = nil %}
{% assign rr_video_url = nil %}
{% assign rr_bubbles_list = nil %}

{% if prod != blank and highlights != blank and highlights.size > 0 %}
  {% comment %} Use for loop to get first entry — highlights[0] returns nil for some metafield list types {% endcomment %}
  {% for h in highlights limit: 1 %}
    {% assign entry = h %}
  {% endfor %}

  {% if entry != blank %}
    {% assign rr_title = entry.title.value | default: entry.title | default: entry.headline.value | default: entry.headline | default: entry.name | default: '' | strip %}
    {% assign rr_description = entry.description.value | default: entry.description | default: '' | strip %}
    {% assign rr_image = entry.image.value | default: entry.image | default: nil %}
    {% assign rr_video_raw = entry.video.value | default: entry.video | default: nil %}
    {% if rr_video_raw != blank %}
      {% if rr_video_raw.sources != blank and rr_video_raw.sources[0].url != blank %}
        {% assign rr_video_url = rr_video_raw.sources[0].url %}
      {% elsif rr_video_raw contains 'http' %}
        {% assign rr_video_url = rr_video_raw %}
      {% endif %}
    {% endif %}
    {% assign bubbles_text = entry.bubbles.value | default: entry.bubbles | default: entry.tags.value | default: entry.tags | default: '' | strip %}
    {% if bubbles_text != blank %}
      {% assign bubbles_normalized = bubbles_text | replace: ', ', '
' | replace: ',', '
' %}
      {% assign rr_bubbles_list = bubbles_normalized | newline_to_br | split: '<br />' %}
    {% endif %}
  {% endif %}
  {% assign has_content = true %}
{% endif %}
{% assign has_visible_content = false %}
{% if rr_title != blank or rr_description != blank or rr_image != blank or rr_video_url != blank or rr_bubbles_list != blank %}
  {% assign has_visible_content = true %}
{% endif %}

{% comment %} Only render when there is visible content. In design mode, show debug/empty state. {% endcomment %}
{% assign accordion_heading = accordion_heading | default: "RESULTS YOU'LL SEE" %}

{% if has_visible_content %}
<div id="sl-rr-block-{{ block_id }}" class="sl-rr-root sl-rr-accordion">
  <details class="accordion group" {% if accordion_open != false %}open{% endif %}>
    <summary>
      <span class="accordion__toggle h6">
        <span>{{ accordion_heading }}</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="12" height="8" viewBox="0 0 12 8" fill="none" class="icon icon-wd-arrow" aria-hidden="true">
          <path d="M11 1L6 7L1 1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
    </summary>
    <div class="accordion__content prose">
      <div class="how-it-affects-container sl-rr-how-it-affects">
        <div class="how-it-affects-box">
          <div class="affect-image sl-rr-media-wrap" {% if rr_video_url != blank %}data-sl-rr-video-trigger{% endif %}>
            {% if rr_video_url != blank %}
              <video
                playsinline
                muted
                autoplay
                loop
                width="600"
                height="600"
                class="sl-rr-video"
                data-sl-rr-video
                {% if rr_image != blank %}poster="{{ rr_image | image_url: width: 600, height: 600 }}"{% endif %}
                style="width: 100%; height: auto; display: block;"
              >
                <source src="{{ rr_video_url }}" type="video/mp4">
              </video>
            {% elsif rr_image != blank %}
              <img
                src="{{ rr_image | image_url: width: 600, height: 600 }}"
                alt="{{ rr_title | escape }}"
                width="600"
                height="600"
                loading="lazy"
                class="sl-rr-poster"
              >
            {% else %}
              <div class="sl-rr-placeholder" style="aspect-ratio: 1; background: #f4f0e9; border-radius: 12px;"></div>
            {% endif %}
          </div>
          <div class="how-it-affect-text-box">
            {% if rr_title != blank %}<p class="title">{{ rr_title }}</p>{% endif %}
            {% if rr_bubbles_list != blank and rr_bubbles_list.size > 0 %}
              <p class="bubles">
                {% for b in rr_bubbles_list %}
                  {% assign b_strip = b | strip %}
                  {% if b_strip != '' %}
                    <span>
                      <svg xmlns="http://www.w3.org/2000/svg" width="12" height="9" viewBox="0 0 12 9" fill="none" aria-hidden="true"><path d="M1 4.53651L4.04336 7.6L10.6 1" stroke="#7D8F3E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      {{ b_strip }}
                    </span>
                  {% endif %}
                {% endfor %}
              </p>
            {% endif %}
            {% if rr_description != blank %}<p class="description">{{ rr_description }}</p>{% endif %}
          </div>
        </div>
      </div>
    </div>
  </details>
</div>
{% elsif request.design_mode %}
<div id="sl-rr-block-{{ block_id }}" class="sl-rr-root sl-rr-accordion" style="padding: 12px; border: 1px dashed #ccc; border-radius: 8px;">
  <p style="margin: 0 0 8px; font-size: 14px; color: #666;"><strong>{{ accordion_heading }}</strong> — No highlights to show. This block is hidden on the storefront.</p>
  <p style="font-size: 12px; color: #888; margin: 0 0 8px;">
    {% if has_content %}This product has highlights but the first entry has no title, description, image or video. Check that your Product Highlight metaobject fields are filled.{% else %}Add <strong>Real results highlights</strong> to this product (Settings → Custom data → Products). Create a Product Highlight metaobject with title, description, image or video, then assign it to this product.{% endif %}
  </p>
  {% if show_debug %}
  <div style="padding:10px;background:#f8f8f8;border:1px solid #ddd;border-radius:6px;font-size:11px;font-family:monospace;">
    <strong>Debug</strong><br>
    Product: {% if prod %}{{ prod.id }} — {{ prod.title }}{% else %}none{% endif %}<br>
    Highlights count: {{ highlights.size | default: 0 }}<br>
    entry: {% if entry != blank %}present{% else %}nil{% endif %}<br>
    has_content: {{ has_content }} | has_visible_content: {{ has_visible_content }}
  </div>
  {% endif %}
</div>
{% endif %}

<style>
  #sl-rr-block-{{ block_id }} .accordion__toggle { display: inline-flex; align-items: center; gap: 8px; cursor: pointer; font-size: 18px; }
  #sl-rr-block-{{ block_id }} .accordion .icon { transition: transform 0.2s; }
  #sl-rr-block-{{ block_id }} .accordion[open] .icon { transform: rotate(180deg); }
  #sl-rr-block-{{ block_id }} .how-it-affects-container { border-radius: 16px; border: 0.5px solid #EBEBEB; background: #FFF; box-shadow: 0 4px 4px -1px rgba(0, 0, 0, 0.02); padding: 20px; }
  #sl-rr-block-{{ block_id }} .how-it-affects-container p.title { color: #272E0F; font-size: 24px; font-weight: 600; line-height: 140%; letter-spacing: 0.16px; margin: 0 0 10px 0; }
  #sl-rr-block-{{ block_id }} .affect-image { position: relative; cursor: pointer; overflow: hidden; border-radius: 13px; }
  #sl-rr-block-{{ block_id }} .affect-image.sl-rr-media-wrap { aspect-ratio: 1; display: block; }
  #sl-rr-block-{{ block_id }} .affect-image .sl-rr-video,
  #sl-rr-block-{{ block_id }} .affect-image .sl-rr-poster { width: 100%; height: 100%; object-fit: cover; display: block; border-radius: 13px; }
  #sl-rr-block-{{ block_id }} .how-it-affects-container p.bubles { margin: 10px 0 0 0; }
  #sl-rr-block-{{ block_id }} .how-it-affects-container p.bubles span { border-radius: 28px; background: #F4F0E9; display: inline-flex; padding: 2px 4px; align-items: center; gap: 4px; margin-right: 6px; margin-bottom: 4px; color: #878787; font-size: 13px; font-weight: 400; }
  #sl-rr-block-{{ block_id }} .how-it-affects-container .how-it-affects-box { display: grid; gap: 16px; }
  #sl-rr-block-{{ block_id }} .how-it-affects-container .how-it-affect-text-box .description { color: #272E0F; font-size: 14px; font-weight: 400; line-height: 150%; letter-spacing: 0.28px; margin: 10px 0 0 0; }
</style>

<script>
(function() {
  var root = document.getElementById('sl-rr-block-{{ block_id }}');
  if (!root) return;
  root.querySelectorAll('[data-sl-rr-video-trigger]').forEach(function(trigger) {
    var video = trigger.querySelector('[data-sl-rr-video]');
    if (video) {
      trigger.addEventListener('click', function() {
        video.classList.toggle('active');
        if (video.classList.contains('active')) video.play && video.play();
        else video.pause && video.pause();
      });
    }
  });
})();
</script>
