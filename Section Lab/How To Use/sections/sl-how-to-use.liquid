{% comment %}
  SL - How to Use (Section)
  Steps from product metaobject: product → single "How to use" (custom.how_to_use) → steps;
  fallback to legacy list custom.how_to_use_steps. Or manual section blocks.
  Add to product template. See README.md.
{% endcomment %}

{% assign step_source = section.settings.step_source | default: 'product_metaobject' %}
{% assign how_to_use = product.metafields.custom.how_to_use.value | default: nil %}
{% assign steps_meta = nil %}
{% if how_to_use != blank and how_to_use.steps != blank %}
  {% assign steps_meta = how_to_use.steps.value | default: how_to_use.steps %}
{% endif %}
{% if steps_meta == blank or steps_meta.size == 0 %}
  {% assign steps_meta = product.metafields.custom.how_to_use_steps.value | default: nil %}
{% endif %}
{% assign use_metaobject = false %}
{% if step_source == 'product_metaobject' and product != blank and steps_meta != blank and steps_meta.size > 0 %}
  {% assign use_metaobject = true %}
{% endif %}

{% assign has_steps = false %}
{% if use_metaobject %}
  {% assign has_steps = true %}
{% elsif step_source == 'section_blocks' and section.blocks.size > 0 %}
  {% assign has_steps = true %}
{% endif %}

{% assign locale_iso = request.locale.iso_code | downcase %}
{% assign is_ar = false %}
{% if locale_iso == 'ar' %}
  {% assign is_ar = true %}
{% endif %}

{% if is_ar %}
  {% assign section_heading_text = section.settings.heading_ar | default: section.settings.heading_en | default: section.settings.heading %}
{% else %}
  {% assign section_heading_text = section.settings.heading_en | default: section.settings.heading_ar | default: section.settings.heading %}
{% endif %}

{% assign layout = section.settings.layout | default: 'vertical' %}

{% unless has_steps %}
  {% if request.design_mode %}
    <div id="sl-htu-section-{{ section.id }}" class="sl-htu-section-root" style="padding: 24px; background: #f5f5f5; border: 2px dashed #ccc; text-align: center;">
      <p style="margin: 0; color: #666;">How to Use — No steps. Choose <strong>Product metaobject</strong> and assign a <strong>How to use (SL)</strong> entry to this product (<code>custom.how_to_use</code>), or use the legacy <strong>How to use steps</strong> list (<code>custom.how_to_use_steps</code>), or choose <strong>Manual steps</strong> and add Step blocks.</p>
    </div>
  {% endif %}
{% else %}
<div id="sl-htu-section-{{ section.id }}" class="sl-htu-section-root sl-htu-layout-{{ layout }}" style="width: 100%; background: {{ section.settings.background_color }}; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="sl-htu-section-inner" style="{% unless section.settings.full_width %}max-width: {{ section.settings.content_width }}px; margin-left: auto; margin-right: auto;{% endunless %} padding-left: {{ section.settings.padding_inline | default: 16 }}px; padding-right: {{ section.settings.padding_inline | default: 16 }}px;">
    <details class="accordion group" open>
      <summary style="text-align: {{ section.settings.heading_alignment }};"{% if is_ar %} dir="rtl"{% endif %}>
        <span class="accordion__toggle" style="color: {{ section.settings.heading_color }}; font-size: {% if section.settings.heading_size == 'small' %}20px{% elsif section.settings.heading_size == 'medium' %}24px{% else %}32px{% endif %}; margin-bottom: {{ section.settings.heading_spacing }}px;">
          {% if section_heading_text != blank %}{{ section_heading_text }}{% else %}How to use{% endif %}
          <svg xmlns="http://www.w3.org/2000/svg" width="12" height="8" viewBox="0 0 12 8" fill="none" class="icon icon-wd-arrow" aria-hidden="true"><path d="M11 1L6 7L1 1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
      </summary>
      <div class="accordion__content">
    <div class="sl-htu-container sl-htu-container--{{ layout }}"{% if is_ar %} dir="rtl"{% endif %}>
      {% if use_metaobject %}
        {% for entry in steps_meta %}
          {% assign step_product = entry.product.value | default: entry.product %}
          {% assign step_num = forloop.index %}
          {% if is_ar %}
            {% assign step_title_text = entry.step_title_ar | default: entry.step_title_en | default: entry.step_title %}
            {% assign step_description = entry.description_ar | default: entry.description_en | default: entry.description %}
          {% else %}
            {% assign step_title_text = entry.step_title_en | default: entry.step_title_ar | default: entry.step_title %}
            {% assign step_description = entry.description_en | default: entry.description_ar | default: entry.description %}
          {% endif %}
          {% if step_title_text == blank %}
            {% capture step_title_text %}Step {{ step_num }}{% endcapture %}
          {% endif %}
          {% assign step_icon = entry.step_icon.value | default: entry.step_icon %}
          <div class="sl-htu-step" data-step="{{ step_num }}">
            <div class="sl-htu-step-title-container">
              {% if step_icon != blank %}
                <span class="sl-htu-step-icon-wrap">
                  <img class="sl-htu-step-icon" src="{{ step_icon | image_url: width: 96 }}" alt="" width="48" height="48" loading="lazy">
                </span>
              {% endif %}
              <span class="sl-htu-step-no">{{ step_num }}</span>
              <span class="sl-htu-step-title">{{ step_title_text }}</span>
            </div>
            {% if step_product != blank %}
              <a href="{{ step_product.url }}" class="sl-htu-step-product-container" aria-label="{{ step_product.title | escape }}">
                <span class="sl-htu-step-product-image" style="background-image: url('{% if step_product.featured_image %}{{ step_product.featured_image | image_url: width: 80 }}{% endif %}');"></span>
                <span class="sl-htu-step-product-name">{{ step_product.title }}</span>
              </a>
            {% endif %}
            {% if step_description != blank %}
              <div class="sl-htu-step-descriptions">
                <div class="sl-htu-step-descriptions-inner prose">{{ step_description }}</div>
              </div>
            {% endif %}
          </div>
        {% endfor %}
      {% else %}
        {% for block in section.blocks %}
          {% if block.type == 'step' %}
            {% assign step_product = block.settings.product %}
            {% assign step_num = forloop.index %}
            {% if is_ar %}
              {% assign step_title_text = block.settings.step_title_ar | default: block.settings.step_title_en | default: block.settings.step_title %}
              {% assign step_description = block.settings.description_ar | default: block.settings.description_en | default: block.settings.description %}
            {% else %}
              {% assign step_title_text = block.settings.step_title_en | default: block.settings.step_title_ar | default: block.settings.step_title %}
              {% assign step_description = block.settings.description_en | default: block.settings.description_ar | default: block.settings.description %}
            {% endif %}
            {% if step_title_text == blank %}
              {% capture step_title_text %}Step {{ step_num }}{% endcapture %}
            {% endif %}
            {% assign step_icon = block.settings.step_icon %}
            <div class="sl-htu-step" data-step="{{ step_num }}" {{ block.shopify_attributes }}>
              <div class="sl-htu-step-title-container">
                {% if step_icon != blank %}
                  <span class="sl-htu-step-icon-wrap">
                    <img class="sl-htu-step-icon" src="{{ step_icon | image_url: width: 96 }}" alt="" width="48" height="48" loading="lazy">
                  </span>
                {% endif %}
                <span class="sl-htu-step-no">{{ step_num }}</span>
                <span class="sl-htu-step-title">{{ step_title_text }}</span>
              </div>
              {% if step_product != blank %}
                <a href="{{ step_product.url }}" class="sl-htu-step-product-container" aria-label="{{ step_product.title | escape }}">
                  <span class="sl-htu-step-product-image" style="background-image: url('{% if step_product.featured_image %}{{ step_product.featured_image | image_url: width: 80 }}{% endif %}');"></span>
                  <span class="sl-htu-step-product-name">{{ step_product.title }}</span>
                </a>
              {% endif %}
              {% if step_description != blank %}
                <div class="sl-htu-step-descriptions">
                  <div class="sl-htu-step-descriptions-inner prose">{{ step_description }}</div>
                </div>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      {% endif %}
    </div>
      </div>
  </details>
  </div>
</div>

<style>
  #sl-htu-section-{{ section.id }} details.accordion { border: none; margin: 0; padding: 0; }
  #sl-htu-section-{{ section.id }} details summary { list-style: none; margin: 0; padding: 0; border: none; }
  #sl-htu-section-{{ section.id }} details summary::-webkit-details-marker { display: none; }
  #sl-htu-section-{{ section.id }} details summary::before,
  #sl-htu-section-{{ section.id }} details summary::after { display: none !important; }
  #sl-htu-section-{{ section.id }} .accordion__toggle {
    display: inline-flex; align-items: center; gap: 8px; cursor: pointer; font-weight: 400; margin: 0; padding: 0;
  }
  #sl-htu-section-{{ section.id }} .accordion .icon { transition: transform 0.2s; }
  #sl-htu-section-{{ section.id }} .accordion[open] .icon { transform: rotate(180deg); }
  #sl-htu-section-{{ section.id }} .accordion__content { margin-top: 8px; padding: 0; }
  #sl-htu-section-{{ section.id }}.sl-htu-section-root {
    --sl-htu-bg: {{ section.settings.step_bg_color | default: '#EEEFE8' }};
    --sl-htu-text: {{ section.settings.step_text_color | default: '#272E0F' }};
    --sl-htu-radius: 44px;
    --sl-htu-step-gap: {{ section.settings.step_gap }}px;
    --sl-htu-steps-per-row: {{ section.settings.horizontal_steps_per_row | default: 3 }};
    box-sizing: border-box;
  }
  #sl-htu-section-{{ section.id }} .sl-htu-section-inner {
    width: 100%;
    box-sizing: border-box;
  }
  /* Vertical layout: steps stack in a column */
  #sl-htu-section-{{ section.id }} .sl-htu-container--vertical {
    display: flex;
    flex-direction: column;
    padding-top: 0;
    gap: 0;
  }
  #sl-htu-section-{{ section.id }} .sl-htu-container--vertical .sl-htu-step {
    margin-top: 0;
  }
  #sl-htu-section-{{ section.id }} .sl-htu-container--vertical .sl-htu-step:first-child .sl-htu-step-title-container {
    margin-top: 0;
  }
  #sl-htu-section-{{ section.id }} .sl-htu-container--vertical .sl-htu-step-title-container {
    margin-top: var(--sl-htu-step-gap);
    margin-block-start: var(--sl-htu-step-gap) !important;
  }
  #sl-htu-section-{{ section.id }} .sl-htu-container--vertical .sl-htu-step:first-child .sl-htu-step-title-container {
    margin-top: 0;
    margin-block-start: 0 !important;
  }
  /* Horizontal layout: steps in a row, wrap on narrow screens */
  #sl-htu-section-{{ section.id }} .sl-htu-container--horizontal {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    align-items: flex-start;
    gap: var(--sl-htu-step-gap);
    padding-top: 0;
  }
  #sl-htu-section-{{ section.id }} .sl-htu-container--horizontal .sl-htu-step {
    flex: 0 0 calc((100% - (var(--sl-htu-steps-per-row) - 1) * var(--sl-htu-step-gap)) / var(--sl-htu-steps-per-row));
    max-width: calc((100% - (var(--sl-htu-steps-per-row) - 1) * var(--sl-htu-step-gap)) / var(--sl-htu-steps-per-row));
    margin-top: 0;
    box-sizing: border-box;
  }
  #sl-htu-section-{{ section.id }} .sl-htu-container--horizontal .sl-htu-step-title-container {
    margin-top: 0;
    margin-block-start: 0 !important;
  }
  #sl-htu-section-{{ section.id }} .sl-htu-step-title-container {
    display: flex;
    align-items: center;
  }
  #sl-htu-section-{{ section.id }} .sl-htu-step-icon-wrap {
    flex-shrink: 0;
    margin-inline-end: 10px;
  }
  #sl-htu-section-{{ section.id }} .sl-htu-step-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
    display: block;
  }
  #sl-htu-section-{{ section.id }} .sl-htu-step-no {
    display: flex; width: 32px; height: 32px; justify-content: center; align-items: center; flex-shrink: 0;
    border-radius: var(--sl-htu-radius); background: var(--sl-htu-bg); color: var(--sl-htu-text);
    font-size: 16px; font-weight: 700; line-height: 1; letter-spacing: 0.02em; text-transform: uppercase;
  }
  #sl-htu-section-{{ section.id }} .sl-htu-step-title {
    color: var(--sl-htu-text); font-size: 16px; font-weight: 700; line-height: 1.2;
    letter-spacing: 0.01em; text-transform: uppercase; padding-inline-start: 12px;
  }
  #sl-htu-section-{{ section.id }} .sl-htu-step-product-container {
    display: grid; align-items: center; grid-template-columns: auto 1fr; gap: 8px;
    padding-block: 10px; padding-inline: 10px 20px; border-radius: 40px; max-width: fit-content; margin-top: 8px;
    background: var(--sl-htu-bg); text-decoration: none; color: inherit; cursor: pointer; transition: opacity 0.2s;
  }
  #sl-htu-section-{{ section.id }} .sl-htu-step-product-container:hover { opacity: 0.85; }
  #sl-htu-section-{{ section.id }} .sl-htu-step-product-image {
    width: 40px; height: 40px; display: block; border-radius: 23px; background-color: #e0e0e0;
    background-size: cover; background-position: center; background-repeat: no-repeat;
  }
  #sl-htu-section-{{ section.id }} .sl-htu-step-product-name {
    color: var(--sl-htu-text); font-size: 13px; font-weight: 400; line-height: 1.3; letter-spacing: 0.01em;
  }
  #sl-htu-section-{{ section.id }} .sl-htu-step-descriptions { margin-top: 16px; }
  #sl-htu-section-{{ section.id }} .sl-htu-step-descriptions-inner {
    margin-top: 12px; color: var(--sl-htu-text); font-size: 14px; font-weight: 400; line-height: 1.5; letter-spacing: 0.02em;
  }
  #sl-htu-section-{{ section.id }} .sl-htu-step-descriptions-inner p { margin: 0 0 0.5em 0; }
  #sl-htu-section-{{ section.id }} .sl-htu-step-descriptions-inner p:last-child { margin-bottom: 0; }
  @media (max-width: 749px) {
    #sl-htu-section-{{ section.id }} .sl-htu-container--horizontal .sl-htu-step {
      flex: 1 1 100%;
      min-width: 100%;
    }
  }
</style>
{% endunless %}

{% schema %}
{
  "name": "SL - How to Use",
  "tag": "section",
  "class": "sl-how-to-use-section",
  "settings": [
    {
      "type": "header",
      "content": "Step source"
    },
    {
      "type": "select",
      "id": "step_source",
      "label": "Step source",
      "info": "Product metaobject = steps from this product's metafield. Manual steps = add Step blocks below.",
      "options": [
        { "value": "product_metaobject", "label": "Product metaobject (per product)" },
        { "value": "section_blocks", "label": "Manual steps (section blocks)" }
      ],
      "default": "product_metaobject"
    },
    {
      "type": "header",
      "content": "Heading (English & Arabic)"
    },
    {
      "type": "text",
      "id": "heading_en",
      "label": "Heading (English)",
      "default": "How to use it the right way"
    },
    {
      "type": "text",
      "id": "heading_ar",
      "label": "Heading (Arabic)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (fallback if locale not en/ar)",
      "info": "Optional. Used when locale is neither English nor Arabic."
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1c1c1c"
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "Heading bottom spacing",
      "min": 0,
      "max": 48,
      "step": 4,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Step styling"
    },
    {
      "type": "color",
      "id": "step_bg_color",
      "label": "Step number & pill background",
      "default": "#EEEFE8"
    },
    {
      "type": "color",
      "id": "step_text_color",
      "label": "Step text color",
      "default": "#272E0F"
    },
    {
      "type": "range",
      "id": "step_gap",
      "label": "Gap between steps",
      "min": 12,
      "max": 48,
      "step": 4,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Section layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Steps layout",
      "info": "Vertical = steps stack in a column. Horizontal = steps in a row (wrap on small screens).",
      "options": [
        { "value": "vertical", "label": "Vertical (stacked)" },
        { "value": "horizontal", "label": "Horizontal (row)" }
      ],
      "default": "vertical"
    },
    {
      "type": "range",
      "id": "horizontal_steps_per_row",
      "label": "Steps per row (horizontal layout)",
      "info": "Number of steps shown in one row on desktop. On mobile, steps stack to one per row.",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 3
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_inline",
      "label": "Padding left & right",
      "min": 8,
      "max": 80,
      "step": 4,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width (screen width)",
      "info": "Section uses full viewport width. Uncheck to constrain content to a max width.",
      "default": true
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Content max width (when not full width)",
      "min": 400,
      "max": 1600,
      "step": 20,
      "default": 1200,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "image_picker",
          "id": "step_icon",
          "label": "Step icon (optional)",
          "info": "Small image or icon shown next to the step number."
        },
        {
          "type": "product",
          "id": "product",
          "label": "Related product"
        },
        {
          "type": "header",
          "content": "Step title (English & Arabic)"
        },
        {
          "type": "text",
          "id": "step_title_en",
          "label": "Step title (English)",
          "info": "Optional. Defaults to \"Step 1\", \"Step 2\", etc."
        },
        {
          "type": "text",
          "id": "step_title_ar",
          "label": "Step title (Arabic)"
        },
        {
          "type": "text",
          "id": "step_title",
          "label": "Step title (fallback)",
          "info": "Used when locale is neither en nor ar."
        },
        {
          "type": "header",
          "content": "Description (English & Arabic)"
        },
        {
          "type": "textarea",
          "id": "description_en",
          "label": "Description (English)",
          "info": "How to use instructions for this step."
        },
        {
          "type": "textarea",
          "id": "description_ar",
          "label": "Description (Arabic)"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description (fallback)",
          "info": "Used when locale is neither en nor ar."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SL - How to Use",
      "category": "Product",
      "settings": { "step_source": "section_blocks", "heading_en": "How to use it the right way" },
      "blocks": [
        { "type": "step", "settings": { "step_title_en": "Step 1", "description_en": "Apply in the morning to cleansed skin." } },
        { "type": "step", "settings": { "step_title_en": "Step 2", "description_en": "Follow with your preferred moisturizer." } },
        { "type": "step", "settings": { "step_title_en": "Step 3", "description_en": "Use daily for best results." } }
      ]
    }
  ],
  "templates": ["product"]
}
{% endschema %}
