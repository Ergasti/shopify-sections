{% comment %}
  SL - How to Use (Snippet)
  Use in product info via Custom Liquid block.
  Usage: {% render 'sl-how-to-use', product: product, block_id: block.id %}
  Requires product.metafields.custom.how_to_use_steps (list of How to use step metaobjects).
  Metaobject fields: product; step_title_en, step_title_ar; description_en, description_ar.
  See README.md for metaobject and metafield setup.
{% endcomment %}

{% assign block_id = block_id | default: 'htu' %}
{% assign prod = product | default: nil %}
{% assign steps = prod.metafields.custom.how_to_use_steps.value | default: nil %}
{% assign has_steps = false %}
{% if prod != blank and steps != blank and steps.size > 0 %}
  {% assign has_steps = true %}
{% endif %}

{% assign locale_iso = request.locale.iso_code | downcase %}
{% assign is_ar = false %}
{% if locale_iso == 'ar' %}
  {% assign is_ar = true %}
{% endif %}

{% if request.design_mode and prod != blank and has_steps == false %}
  <div id="sl-htu-block-{{ block_id }}" class="sl-htu-block-root" style="padding: 12px; color: #666; border: 1px dashed #ccc;">
    <p style="margin: 0;">How to Use — No steps. Add entries to this product's <strong>How to use steps</strong> metafield (<code>custom.how_to_use_steps</code>).</p>
  </div>
{% endif %}

{% if has_steps %}
<div id="sl-htu-block-{{ block_id }}" class="sl-htu-block-root sl-htu-container"{% if is_ar %} dir="rtl"{% endif %}>
  {% for entry in steps %}
    {% assign step_product = entry.product.value | default: entry.product %}
    {% assign step_num = forloop.index %}
    {% if is_ar %}
      {% assign step_title_text = entry.step_title_ar | default: entry.step_title_en | default: entry.step_title %}
      {% assign step_description = entry.description_ar | default: entry.description_en | default: entry.description %}
    {% else %}
      {% assign step_title_text = entry.step_title_en | default: entry.step_title_ar | default: entry.step_title %}
      {% assign step_description = entry.description_en | default: entry.description_ar | default: entry.description %}
    {% endif %}
    {% if step_title_text == blank %}
      {% capture step_title_text %}Step {{ step_num }}{% endcapture %}
    {% endif %}

    <div class="sl-htu-step" data-step="{{ step_num }}">
      <div class="sl-htu-step-title-container">
        <span class="sl-htu-step-no">{{ step_num }}</span>
        <span class="sl-htu-step-title">{{ step_title_text }}</span>
      </div>

      {% if step_product != blank %}
        <a href="{{ step_product.url }}" class="sl-htu-step-product-container" aria-label="{{ step_product.title | escape }}">
          <span
            class="sl-htu-step-product-image"
            style="background-image: url('{% if step_product.featured_image %}{{ step_product.featured_image | image_url: width: 80 }}{% endif %}');"
          ></span>
          <span class="sl-htu-step-product-name">{{ step_product.title }}</span>
        </a>
      {% endif %}

      {% if step_description != blank %}
        <div class="sl-htu-step-descriptions">
          <div class="sl-htu-step-descriptions-inner prose">{{ step_description }}</div>
        </div>
      {% endif %}
    </div>
  {% endfor %}
</div>

<style>
  #sl-htu-block-{{ block_id }}.sl-htu-block-root {
    --sl-htu-bg: #EEEFE8;
    --sl-htu-text: #272E0F;
    --sl-htu-radius: 44px;
    --sl-htu-step-gap: 24px;
  }
  #sl-htu-block-{{ block_id }} .sl-htu-container {
    padding-top: 22px;
  }
  #sl-htu-block-{{ block_id }} .sl-htu-step {
    margin-top: 0;
  }
  #sl-htu-block-{{ block_id }} .sl-htu-step:first-child .sl-htu-step-title-container {
    margin-top: 0;
  }
  #sl-htu-block-{{ block_id }} .sl-htu-step-title-container {
    display: flex;
    align-items: center;
    margin-top: var(--sl-htu-step-gap);
    margin-block-start: var(--sl-htu-step-gap) !important;
  }
  #sl-htu-block-{{ block_id }} .sl-htu-step-no {
    display: flex;
    width: 32px;
    height: 32px;
    justify-content: center;
    align-items: center;
    flex-shrink: 0;
    border-radius: var(--sl-htu-radius);
    background: var(--sl-htu-bg);
    color: var(--sl-htu-text);
    font-size: 16px;
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }
  #sl-htu-block-{{ block_id }} .sl-htu-step-title {
    color: var(--sl-htu-text);
    font-size: 16px;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    padding-left: 12px;
  }
  #sl-htu-block-{{ block_id }} .sl-htu-step-product-container {
    display: grid;
    align-items: center;
    grid-template-columns: auto 1fr;
    gap: 8px;
    padding: 10px 20px 10px 10px;
    border-radius: 40px;
    max-width: fit-content;
    margin-top: 8px;
    background: var(--sl-htu-bg);
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  #sl-htu-block-{{ block_id }} .sl-htu-step-product-container:hover {
    opacity: 0.85;
  }
  #sl-htu-block-{{ block_id }} .sl-htu-step-product-image {
    width: 40px;
    height: 40px;
    display: block;
    border-radius: 23px;
    background-color: #e0e0e0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }
  #sl-htu-block-{{ block_id }} .sl-htu-step-product-name {
    color: var(--sl-htu-text);
    font-size: 13px;
    font-weight: 400;
    line-height: 1.3;
    letter-spacing: 0.01em;
  }
  #sl-htu-block-{{ block_id }} .sl-htu-step-descriptions {
    margin-top: 16px;
  }
  #sl-htu-block-{{ block_id }} .sl-htu-step-descriptions-inner {
    margin-top: 0;
    color: var(--sl-htu-text);
    font-size: 14px;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: 0.02em;
  }
  #sl-htu-block-{{ block_id }} .sl-htu-step-descriptions-inner p {
    margin: 0 0 0.5em 0;
  }
  #sl-htu-block-{{ block_id }} .sl-htu-step-descriptions-inner p:last-child {
    margin-bottom: 0;
  }
</style>
{% endif %}
