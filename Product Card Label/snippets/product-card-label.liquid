{% comment %}
  On-image product card label (e.g. "Inspired By" / category).
  Renders in bottom-right corner of the card image when the metafield has a value.

  Usage (in your theme's product card snippet, inside .card__media):
    {% render 'product-card-label', product: product %}

  Optional: custom metafield
    {% render 'product-card-label', product: product, metafield_key: 'custom.category' %}

  Metafield: default custom.inspired_by (single line text). Create in Settings → Custom data → Products.
{% endcomment %}

{% assign field_key = metafield_key | default: 'custom.inspired_by' %}
{% assign namespace_key = field_key | split: '.' %}
{% assign ns = namespace_key[0] %}
{% assign key = namespace_key[1] %}
{% if product == blank %}
  {% assign label_value = '' %}
{% elsif ns == 'custom' %}
  {% assign mf = product.metafields.custom[key] %}
  {% if mf != blank %}
    {% assign label_value = mf.value | default: mf | strip %}
  {% else %}
    {% assign label_value = '' %}
  {% endif %}
{% else %}
  {% assign mf = product.metafields[ns][key] %}
  {% if mf != blank %}
    {% assign label_value = mf.value | default: mf | strip %}
  {% else %}
    {% assign label_value = '' %}
  {% endif %}
{% endif %}

{% if label_value != blank %}
  {% comment %} Output CSS only once per page to avoid repeating the same style on every card {% endcomment %}
  {% unless product_card_label_css_output %}
    {% assign product_card_label_css_output = true %}
    <style>
      
      .product-card-label {
        position: absolute;
        bottom: 0;
        right: 0;
        z-index: 2;
        padding: 5px 5px;
        margin: 3px;
        background: rgba(0, 0, 0, 0.7);
        color: #fff;
        font-size: 1rem;
        line-height: 1.2;
        border-radius: 4px;
        max-width: calc(100% - 16px);
        text-align: right;
        pointer-events: none;
      }
      .product-card-label__text {
        display: block;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
    </style>
  {% endunless %}
  <div class="product-card-label" aria-hidden="true">
    <span class="product-card-label__text">{{ label_value }}</span>
  </div>
{% endif %}
